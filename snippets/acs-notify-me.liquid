{% comment %}
  Acharkhastory — Notify Me (Back in Stock)
  Email capture rendered when variant is sold out.
{% endcomment %}

<div class="acs-notify-me" data-acs-notify-me hidden>
  <p class="acs-notify-me__heading">
    <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true"><path d="M10 2a6 6 0 016 6v3l2 2H2l2-2V8a6 6 0 016-6z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 15a2 2 0 004 0" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
    Notify me when back in stock
  </p>
  <form class="acs-notify-me__form" data-acs-notify-form>
    <div class="acs-notify-me__row">
      <input type="email" class="acs-notify-me__input" placeholder="Enter your email" required data-acs-notify-email autocomplete="email">
      <button type="submit" class="acs-notify-me__submit">Notify Me</button>
    </div>
    <p class="acs-notify-me__status" data-acs-notify-status hidden aria-live="polite"></p>
  </form>
  <p class="acs-notify-me__note">We'll email you once when this item is restocked.</p>
</div>

<script>
(function(){
  var c=document.querySelector('[data-acs-notify-me]');if(!c)return;
  var f=c.querySelector('[data-acs-notify-form]'),e=c.querySelector('[data-acs-notify-email]'),s=c.querySelector('[data-acs-notify-status]');
  f&&f.addEventListener('submit',function(ev){ev.preventDefault();var em=e&&e.value.trim();if(!em)return;
    var n=JSON.parse(localStorage.getItem('acs-notify-requests')||'[]');
    n.push({email:em,product:location.pathname.split('/').pop(),date:new Date().toISOString()});
    localStorage.setItem('acs-notify-requests',JSON.stringify(n));
    if(s){s.textContent='We will notify you at '+em;s.removeAttribute('hidden');}
    if(e)e.disabled=true;f.querySelector('.acs-notify-me__submit').disabled=true;
  });
})();
</script>
