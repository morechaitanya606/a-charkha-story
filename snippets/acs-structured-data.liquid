{% comment %}
  Acharkhastory — Structured Data (JSON-LD)
  Renders Organization, Product, BreadcrumbList, and FAQPage structured data.
  Include in theme.liquid or per-template.
{% endcomment %}

{%- if request.page_type == 'index' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "logo": {%- if settings.logo -%}{{ settings.logo | image_url: width: 600 | json }}{%- else -%}""{%- endif -%},
      "description": {{ shop.description | json }},
      "sameAs": [
        {%- liquid
          assign wrote_social = false
          if settings.social_facebook_link != blank
            echo settings.social_facebook_link | json
            assign wrote_social = true
          endif
          if settings.social_instagram_link != blank
            if wrote_social
              echo ','
            endif
            echo settings.social_instagram_link | json
            assign wrote_social = true
          endif
          if settings.social_twitter_link != blank
            if wrote_social
              echo ','
            endif
            echo settings.social_twitter_link | json
          endif
        -%}
      ]
    }
  </script>
{%- endif -%}

{%- if request.page_type == 'product' and product != blank -%}
  {%- liquid
    assign selected_variant = product.selected_or_first_available_variant
    assign breadcrumb_collection = collection
    if breadcrumb_collection == blank and product.collections.size > 0
      assign breadcrumb_collection = product.collections.first
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ shop.url | json }}
        }
        {%- if breadcrumb_collection != blank -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ breadcrumb_collection.title | json }},
            "item": {{ shop.url | append: breadcrumb_collection.url | json }}
          }
          ,{
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }}
          }
        {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.title | json }}
          }
        {%- endif -%}
      ]
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 500 | json }},
      "url": {{ shop.url | append: product.url | json }},
      "image": [
        {%- liquid
          assign wrote_image = false
          for media in product.media limit: 5
            if media.preview_image != blank
              if wrote_image
                echo ','
              endif
              echo media.preview_image | image_url: width: 1200 | json
              assign wrote_image = true
            endif
          endfor
        -%}
      ],
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | default: shop.name | json }}
      },
      "sku": {{ selected_variant.sku | json }},
      "offers": {
        "@type": "Offer",
        "url": {{ shop.url | append: product.url | json }},
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": {{ selected_variant.price | divided_by: 100.0 | json }},
        "availability": {%- if selected_variant.available -%}"https://schema.org/InStock"{%- else -%}"https://schema.org/OutOfStock"{%- endif -%},
        "seller": {
          "@type": "Organization",
          "name": {{ shop.name | json }}
        }
      }
      {%- if product.metafields.judgeme.review_count != blank and product.metafields.judgeme.review_count > 0 -%}
        ,"aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": {{ product.metafields.judgeme.average_rating | json }},
          "reviewCount": {{ product.metafields.judgeme.review_count | json }}
        }
      {%- endif -%}
    }
  </script>
{%- endif -%}

{%- if request.page_type == 'collection' and collection != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ shop.url | json }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }}
        }
      ]
    }
  </script>
{%- endif -%}

{%- if request.page_type == 'article' and article != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": {{ article.title | json }},
      "description": {{ article.excerpt_or_content | strip_html | truncate: 300 | json }},
      "url": {{ shop.url | append: article.url | json }},
      "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
      "dateModified": {{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
      "author": {
        "@type": "Person",
        "name": {{ article.author | json }}
      },
      "publisher": {
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "logo": {%- if settings.logo -%}{{ settings.logo | image_url: width: 600 | json }}{%- else -%}""{%- endif -%}
      }
      {%- if article.image != blank -%}
        ,"image": {{ article.image | image_url: width: 1200 | json }}
      {%- endif -%}
    }
  </script>
{%- endif -%}

{%- if template.suffix == 'faq' -%}
  {%- assign faq_page = pages['faq'] -%}
  {%- if faq_page != blank and faq_page.content contains '<h' -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": []
      }
    </script>
  {%- endif -%}
{%- endif -%}
