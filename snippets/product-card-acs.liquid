{% comment %}
  Acharkhastory product card.
  Accepts:
  - product
  - show_badge
  - show_craft_tag
  - show_quick_add
  - show_wishlist
  - card_index
  - sale_label, new_label, bestseller_label, wishlist_label, add_label, select_label, sold_out_label
{% endcomment %}

{% liquid
  assign show_badge = show_badge | default: true
  assign show_craft_tag = show_craft_tag | default: true
  assign show_quick_add = show_quick_add | default: true
  assign show_wishlist = show_wishlist | default: true
  assign card_index = card_index | default: 0
  assign sale_label = sale_label | default: 'Sale'
  assign new_label = new_label | default: 'New'
  assign bestseller_label = bestseller_label | default: 'Bestseller'
  assign wishlist_label = wishlist_label | default: 'Add to wishlist'
  assign add_label = add_label | default: 'Add to Bag'
  assign select_label = select_label | default: 'Select Options'
  assign sold_out_label = sold_out_label | default: 'Sold Out'
  assign loading = 'lazy'

  if card_index == 1
    assign loading = 'eager'
  endif
%}

{%- if product != blank -%}
  <article class="product-card-acs acs-card-lift acs-reveal" data-product-id="{{ product.id }}" data-acs-delay="{{ card_index }}">
    <div class="product-card-acs__media">
      <a href="{{ product.url }}" class="product-card-acs__media-link" aria-label="{{ product.title | escape }}">
        {%- if product.featured_image != blank -%}
          <img
            class="product-card-acs__img product-card-acs__img--primary"
            src="{{ product.featured_image | image_url: width: 600 }}"
            srcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 768px) 50vw, 280px"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            loading="{{ loading }}"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
          >

          {%- if product.images.size > 1 -%}
            <img
              class="product-card-acs__img product-card-acs__img--hover"
              src="{{ product.images[1] | image_url: width: 600 }}"
              srcset="{{ product.images[1] | image_url: width: 300 }} 300w, {{ product.images[1] | image_url: width: 600 }} 600w"
              sizes="(max-width: 768px) 50vw, 280px"
              alt="{{ product.images[1].alt | default: product.title | escape }}"
              loading="lazy"
              width="{{ product.images[1].width }}"
              height="{{ product.images[1].height }}"
            >
          {%- endif -%}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </a>

      {%- if show_badge -%}
        {%- if product.compare_at_price > product.price -%}
          <span class="product-card-acs__badge acs-badge acs-badge--sale">{{ sale_label | escape }}</span>
        {%- elsif product.tags contains 'new' -%}
          <span class="product-card-acs__badge acs-badge acs-badge--new">{{ new_label | escape }}</span>
        {%- elsif product.tags contains 'bestseller' -%}
          <span class="product-card-acs__badge acs-badge acs-badge--bestseller">
            {{ bestseller_label | escape }}
          </span>
        {%- endif -%}
      {%- endif -%}

      {%- if show_wishlist -%}
        <button
          class="product-card-acs__wishlist"
          type="button"
          aria-label="{{ wishlist_label | escape }}"
          data-product-handle="{{ product.handle }}"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
      {%- endif -%}

      {%- if show_quick_add -%}
        <div class="product-card-acs__quick-add">
          {%- if product.available -%}
            {%- if product.variants.size == 1 -%}
              <form action="{{ routes.cart_add_url }}" method="post" data-acs-ajax-add>
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <button type="submit" class="product-card-acs__add-btn" aria-label="Add {{ product.title | escape }} to bag">{{ add_label | escape }}</button>
              </form>
            {%- else -%}
              <a href="{{ product.url }}" class="product-card-acs__add-btn">{{ select_label | escape }}</a>
            {%- endif -%}
          {%- else -%}
            <button class="product-card-acs__add-btn" type="button" disabled>
              {{ sold_out_label | escape }}
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="product-card-acs__info">
      {%- if show_craft_tag -%}
        {%- for tag in product.tags -%}
          {%- if tag contains 'craft_' -%}
            <span class="product-card-acs__craft-tag">
              {{ tag | remove: 'craft_' | replace: '-', ' ' | escape }}
            </span>
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      <a href="{{ product.url }}" class="product-card-acs__title-link">
        <h3 class="product-card-acs__title">{{ product.title | escape }}</h3>
      </a>

      <div class="product-card-acs__price-row">
        {%- if product.compare_at_price > product.price -%}
          <span class="product-card-acs__price product-card-acs__price--sale">{{ product.price | money }}</span>
          <span class="product-card-acs__compare">{{ product.compare_at_price | money }}</span>
        {%- else -%}
          <span class="product-card-acs__price">{{ product.price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </article>
{%- endif -%}
