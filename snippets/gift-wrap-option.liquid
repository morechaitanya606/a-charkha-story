{% comment %}
  Acharkhastory — Gift Wrap Option
  Toggleable gift wrap checkbox on PDP.
  Adds a "Gift Wrap" line item property + optional custom message.
{% endcomment %}

{%- liquid
  assign gift_wrap_price = section.settings.gift_wrap_price | default: 99
  assign gift_wrap_label = section.settings.gift_wrap_label | default: 'Add gift wrapping'
-%}

<div class="acs-gift-wrap" data-acs-gift-wrap>
  <label class="acs-gift-wrap__toggle">
    <input type="checkbox" name="properties[Gift Wrap]" value="Yes" data-acs-gift-wrap-check>
    <span class="acs-gift-wrap__checkbox" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="12" height="12"><path d="M3 8l3 3 7-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
    <span class="acs-gift-wrap__label">
      <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true"><rect x="3" y="8" width="14" height="9" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M3 8h14M10 8v9" stroke="currentColor" stroke-width="1.5"/><path d="M10 7c-3 0-4.5-.8-4.5-2.5a2 2 0 013.5-1.3c.5.6 1 1.8 1 3.8z" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M10 7c3 0 4.5-.8 4.5-2.5a2 2 0 00-3.5-1.3c-.5.6-1 1.8-1 3.8z" fill="none" stroke="currentColor" stroke-width="1.2"/></svg>
      {{ gift_wrap_label | escape }}
      <span class="acs-gift-wrap__price">+₹{{ gift_wrap_price }}</span>
    </span>
  </label>

  <div class="acs-gift-wrap__message" data-acs-gift-message hidden>
    <textarea
      name="properties[Gift Message]"
      class="acs-gift-wrap__textarea"
      placeholder="Write a personal message (optional)"
      maxlength="200"
      rows="3"
    ></textarea>
    <span class="acs-gift-wrap__char-count"><span data-acs-char-count>0</span>/200</span>
  </div>
</div>

<script>
  (function() {
    const wrap = document.querySelector('[data-acs-gift-wrap]');
    if (!wrap) return;

    const checkbox = wrap.querySelector('[data-acs-gift-wrap-check]');
    const messageBox = wrap.querySelector('[data-acs-gift-message]');
    const textarea = wrap.querySelector('.acs-gift-wrap__textarea');
    const charCount = wrap.querySelector('[data-acs-char-count]');

    checkbox?.addEventListener('change', function() {
      if (checkbox.checked) {
        messageBox?.removeAttribute('hidden');
      } else {
        messageBox?.setAttribute('hidden', '');
        if (textarea) textarea.value = '';
        if (charCount) charCount.textContent = '0';
      }
    });

    textarea?.addEventListener('input', function() {
      if (charCount) charCount.textContent = textarea.value.length;
    });
  })();
</script>

<style>
  .acs-gift-wrap {
    display: grid;
    gap: var(--acs-space-sm);
    padding: var(--acs-space-md);
    border: var(--acs-border-subtle);
    border-radius: var(--acs-radius-md);
    background: rgb(var(--acs-color-white-rgb) / 0.52);
  }

  .acs-gift-wrap__toggle {
    display: flex;
    align-items: center;
    gap: var(--acs-space-sm);
    cursor: pointer;
  }

  .acs-gift-wrap__toggle input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .acs-gift-wrap__checkbox {
    display: grid;
    place-items: center;
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    border: 2px solid var(--acs-color-border);
    border-radius: var(--acs-radius-xs);
    background: var(--acs-color-white);
    color: transparent;
    transition: background var(--acs-duration-base) var(--acs-ease), border-color var(--acs-duration-base) var(--acs-ease), color var(--acs-duration-base) var(--acs-ease);
  }

  .acs-gift-wrap__toggle input:checked + .acs-gift-wrap__checkbox {
    background: var(--acs-color-accent);
    border-color: var(--acs-color-accent);
    color: var(--acs-color-white);
  }

  .acs-gift-wrap__label {
    display: flex;
    align-items: center;
    gap: var(--acs-space-xs);
    font-size: var(--acs-type-small);
    font-weight: 600;
    color: var(--acs-color-primary);
  }

  .acs-gift-wrap__label svg {
    color: var(--acs-color-accent);
  }

  .acs-gift-wrap__price {
    color: var(--acs-color-muted);
    font-weight: 500;
  }

  .acs-gift-wrap__message {
    display: grid;
    gap: var(--acs-space-2xs);
  }

  .acs-gift-wrap__textarea {
    width: 100%;
    min-height: 5rem;
    border: var(--acs-border-subtle);
    border-radius: var(--acs-radius-sm);
    background: var(--acs-color-white);
    color: var(--acs-color-ink);
    font-family: var(--acs-font-body);
    font-size: var(--acs-type-small);
    padding: var(--acs-space-sm);
    resize: vertical;
    transition: border-color var(--acs-duration-base) var(--acs-ease);
  }

  .acs-gift-wrap__textarea:focus {
    border-color: var(--acs-color-accent);
    outline: 0;
    box-shadow: var(--acs-focus-ring);
  }

  .acs-gift-wrap__char-count {
    text-align: right;
    color: var(--acs-color-muted);
    font-size: var(--acs-type-caption);
  }
</style>
