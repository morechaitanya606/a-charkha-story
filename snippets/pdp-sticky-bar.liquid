{% comment %}
  ACHARKHASTORY — PDP Sticky Mobile Add-to-Bag Bar
  Render this at the bottom of product templates.
  Becomes visible when product title scrolls out of view (via pdp-enhancements.js).
{% endcomment %}

<div class="pdp-sticky-bar" aria-label="Quick add to bag">
  <div class="pdp-sticky-bar__info">
    <div class="pdp-sticky-bar__title">{{ product.title }}</div>
    <div class="pdp-sticky-bar__price">
      {%- if product.compare_at_price > product.price -%}
        <span style="color: var(--acs-sale);">{{ product.price | money }}</span>
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </div>
  </div>
  <form action="/cart/add" method="post">
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit" class="pdp-sticky-bar__btn"{% unless product.available %} disabled{% endunless %}>
      {%- if product.available -%}Add to Bag{%- else -%}Sold Out{%- endif -%}
    </button>
  </form>
</div>
