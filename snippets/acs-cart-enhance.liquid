{% comment %}
  Cart Enhancement Snippet
  Adds free shipping progress bar, trust badges, and gift wrap to the cart page.
  Rendered via layout/theme.liquid or injected into cart template.
{% endcomment %}

{%- liquid
  assign free_ship_threshold = 1499
  assign cart_total = cart.total_price | divided_by: 100
  assign remaining = free_ship_threshold | minus: cart_total
  assign progress = cart_total | times: 100.0 | divided_by: free_ship_threshold
  if progress > 100
    assign progress = 100
  endif
-%}

<div class="acs-cart-enhance" data-acs-cart-enhance>
  {%- if cart.item_count > 0 -%}
    <div class="acs-cart-shipping-bar">
      {%- if remaining > 0 -%}
        <p class="acs-cart-shipping-bar__text">
          <span aria-hidden="true">🚚</span>
          You're <strong>₹{{ remaining }}</strong> away from <strong>free shipping!</strong>
        </p>
      {%- else -%}
        <p class="acs-cart-shipping-bar__text acs-cart-shipping-bar__text--success">
          <span aria-hidden="true">✓</span>
          You've unlocked <strong>free shipping!</strong>
        </p>
      {%- endif -%}
      <div class="acs-cart-shipping-bar__track">
        <div class="acs-cart-shipping-bar__fill" style="width: {{ progress }}%;" aria-valuenow="{{ progress }}" aria-valuemin="0" aria-valuemax="100" role="progressbar" aria-label="Free shipping progress"></div>
      </div>
    </div>
  {%- endif -%}

  <div class="acs-cart-trust">
    <div class="acs-cart-trust__item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <path d="M9 12l2 2 4-5"/>
      </svg>
      <span>Secure checkout</span>
    </div>
    <div class="acs-cart-trust__item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 7v6h6"/>
        <path d="M5.5 15a7 7 0 1 0 1.7-7.2L4 13"/>
      </svg>
      <span>15-day easy returns</span>
    </div>
    <div class="acs-cart-trust__item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 7h11v10H3z"/>
        <path d="M14 10h4l3 4v3h-7z"/>
        <circle cx="7" cy="19" r="2"/>
        <circle cx="18" cy="19" r="2"/>
      </svg>
      <span>Free delivery above ₹1,499</span>
    </div>
    <div class="acs-cart-trust__item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 21c0-6-5-10-10-10 2-7 6-10 10-8 4-2 8 1 10 8-5 0-10 4-10 10z"/>
        <path d="M12 8v13"/>
      </svg>
      <span>100% handmade</span>
    </div>
  </div>
</div>

<style>
  .acs-cart-enhance {
    margin-top: var(--acs-space-xl);
  }

  .acs-cart-shipping-bar {
    background: var(--acs-color-cream);
    border-radius: var(--acs-radius-md);
    padding: var(--acs-space-md) var(--acs-space-lg);
    margin-bottom: var(--acs-space-lg);
  }

  .acs-cart-shipping-bar__text {
    font-size: var(--acs-type-small);
    color: var(--acs-color-ink);
    margin: 0 0 var(--acs-space-sm);
    text-align: center;
  }

  .acs-cart-shipping-bar__text--success {
    color: var(--acs-color-success);
    font-weight: 600;
  }

  .acs-cart-shipping-bar__track {
    width: 100%;
    height: 6px;
    background: var(--acs-color-border);
    border-radius: var(--acs-radius-full);
    overflow: hidden;
  }

  .acs-cart-shipping-bar__fill {
    height: 100%;
    background: var(--acs-color-success);
    border-radius: var(--acs-radius-full);
    transition: width 0.6s var(--acs-ease);
  }

  .acs-cart-trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--acs-space-sm);
    padding: var(--acs-space-md);
    border: var(--acs-border-subtle);
    border-radius: var(--acs-radius-md);
    background: var(--acs-color-white);
  }

  .acs-cart-trust__item {
    display: flex;
    gap: var(--acs-space-xs);
    align-items: center;
    color: var(--acs-color-muted);
    font-size: var(--acs-type-caption);
  }

  .acs-cart-trust__item svg {
    color: var(--acs-color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .acs-cart-trust {
      grid-template-columns: 1fr;
    }
  }
</style>
