{% comment %}
  About Page — Values Grid
  Three-column grid showcasing brand pillars: Handmade, Sustainable, Fair Trade.
  Usage: Include via templates/page.about.json
{% endcomment %}

<section class="acs-values acs-section" id="about-values">
  <div class="acs-page-width">
    <div class="acs-section-header acs-section-header--center">
      <h2 class="acs-h2">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="acs-section-header__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="acs-values__grid">
      {%- for block in section.blocks -%}
        <div class="acs-value-card" {{ block.shopify_attributes }}>
          <div class="acs-value-card__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'handmade' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 11V6a2 2 0 00-2-2 2 2 0 00-2 2v0"/>
                  <path d="M14 10V4a2 2 0 00-2-2 2 2 0 00-2 2v2"/>
                  <path d="M10 10.5V6a2 2 0 00-2-2 2 2 0 00-2 2v8"/>
                  <path d="M18 8a2 2 0 012 2v7.1a5 5 0 01-.8 2.7l-.6.9a1 1 0 01-.8.4h-8.4a1 1 0 01-.7-.3l-3.1-3.1a2 2 0 010-2.8l.5-.5a2 2 0 012.8 0L10 16V6"/>
                </svg>
              {%- when 'sustainable' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 22c1.25-.99 2.67-1.8 4.2-2.4 3.79-1.47 7.81-1.47 11.6 0 1.53.6 2.95 1.41 4.2 2.4"/>
                  <path d="M12 2c-3.73 4.63-3 10-3 10s4.09-1.77 7.14-5.29"/>
                  <path d="M12 2c3.73 4.63 3 10 3 10s-4.09-1.77-7.14-5.29"/>
                  <path d="M12 12v10"/>
                </svg>
              {%- when 'fair-trade' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <path d="M9 12l2 2 4-5"/>
                </svg>
              {%- when 'heritage' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                </svg>
              {%- when 'community' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                  <path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- endcase -%}
          </div>

          <h3 class="acs-value-card__title">{{ block.settings.title }}</h3>
          <p class="acs-value-card__body">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Values",
  "tag": "section",
  "class": "acs-about-values-section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "What We Stand For" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Three principles guide every decision we make — from the loom to your door." }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "handmade", "label": "Handmade (hands)" },
            { "value": "sustainable", "label": "Sustainable (leaf)" },
            { "value": "fair-trade", "label": "Fair Trade (shield)" },
            { "value": "heritage", "label": "Heritage (heart)" },
            { "value": "community", "label": "Community (people)" }
          ],
          "default": "handmade"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Handmade" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Every piece is crafted by hand — no machines, no shortcuts. From dyeing and printing to weaving and stitching, each step is done by artisan hands." }
      ]
    }
  ],
  "presets": [{
    "name": "About Values",
    "blocks": [
      { "type": "value", "settings": { "icon": "handmade", "title": "100% Handmade", "description": "Every piece is crafted by hand — no machines, no shortcuts. From dyeing and printing to weaving and stitching, each step is done by artisan hands." }},
      { "type": "value", "settings": { "icon": "sustainable", "title": "Sustainable Materials", "description": "Natural dyes, organic cotton, and zero-waste processes. We choose materials that respect the earth and the people who work with them." }},
      { "type": "value", "settings": { "icon": "fair-trade", "title": "Fair & Direct Trade", "description": "We pay artisans fairly and work directly with cooperatives — no middlemen. Your purchase supports families and keeps craft traditions alive." }}
    ]
  }]
}
{% endschema %}
