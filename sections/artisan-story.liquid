{% comment %}
  Acharkhastory artisan story.
  Mission-led trust section with image, narrative, and impact stats.
{% endcomment %}

{% liquid
  assign title = section.settings.title | strip
  assign body = section.settings.body | strip
  assign image = section.settings.image
  assign cta_link = section.settings.cta_link | default: routes.root_url
%}

<section class="acs-section acs-artisan-story" id="ArtisanStory-{{ section.id }}">
  <div class="acs-container">
    <div class="acs-artisan-story__grid">
      <div class="acs-artisan-story__media">
        {%- if image != blank -%}
          <img
            src="{{ image | image_url: width: 900 }}"
            srcset="{{ image | image_url: width: 540 }} 540w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 768px) 100vw, 45vw"
            width="{{ image.width }}"
            height="{{ image.height }}"
            alt="{{ section.settings.image_alt | default: title | escape }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      <div class="acs-artisan-story__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="acs-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if title != blank -%}
          <h2 class="acs-h2">{{ title | escape }}</h2>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="acs-artisan-story__stats">
            {%- for block in section.blocks -%}
              {%- if block.settings.number != blank or block.settings.label != blank -%}
                <div class="acs-artisan-story__stat" {{ block.shopify_attributes }}>
                  {%- if block.settings.number != blank -%}
                    <span class="acs-artisan-story__stat-number">{{ block.settings.number | escape }}</span>
                  {%- endif -%}

                  {%- if block.settings.label != blank -%}
                    <span class="acs-artisan-story__stat-label">{{ block.settings.label | escape }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if body != blank -%}
          <p class="acs-artisan-story__text">{{ body | escape }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <div>
            <a class="acs-button acs-button--primary" href="{{ cta_link }}">
              {{ section.settings.cta_label | escape }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ACS Artisan Story",
  "tag": "section",
  "class": "shopify-section--acs-artisan-story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Artisan photo"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Indian artisan working on handmade textile craft"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Artisan Collective"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline",
      "default": "2,300 hands craft every collection"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Every Acharkhastory product is handcrafted by skilled artisans from cooperatives across India. When you buy from us, you sustain a family, revive a craft, and wear a piece of living heritage."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Meet Our Artisans"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "2,300+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Artisans"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "ACS Artisan Story",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "number": "2,300+",
            "label": "Artisans"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "12",
            "label": "States"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "40+",
            "label": "Cooperatives"
          }
        }
      ]
    }
  ]
}
{% endschema %}
