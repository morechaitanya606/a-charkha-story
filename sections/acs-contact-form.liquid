{% comment %}
  Contact Page — Form + Info Sidebar
  Uses Shopify's native /contact endpoint for form submission.
  Usage: Include via templates/page.contact-us.json
{% endcomment %}

<section class="acs-section" id="contact-form">
  <div class="acs-page-width">
    <div class="acs-contact-layout">

      {%- comment %} ---- FORM COLUMN ---- {%- endcomment -%}
      <div>
        <h2 class="acs-h3" style="margin-bottom:var(--acs-space-lg);">{{ section.settings.form_title }}</h2>

        {%- form 'contact', id: 'acs-contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="acs-contact-success">
              <div class="acs-contact-success__icon" aria-hidden="true">✓</div>
              <h3 class="acs-h4">{{ section.settings.success_heading }}</h3>
              <p class="acs-muted" style="margin-top:var(--acs-space-sm);">{{ section.settings.success_body }}</p>
            </div>
          {%- else -%}
            {%- if form.errors -%}
              <div class="acs-form-error" role="alert" style="background:rgb(var(--acs-color-sale-rgb)/0.08);border:1px solid var(--acs-color-sale);border-radius:var(--acs-radius-sm);padding:var(--acs-space-md);margin-bottom:var(--acs-space-lg);color:var(--acs-color-sale);font-size:var(--acs-type-small);">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="acs-contact-form">
              <div class="acs-contact-form__row">
                <div class="acs-contact-form__field">
                  <label for="contact-name" class="acs-contact-form__label">Name *</label>
                  <input
                    type="text"
                    id="contact-name"
                    name="contact[name]"
                    class="acs-contact-form__input"
                    placeholder="Your full name"
                    required
                    autocomplete="name"
                  >
                </div>
                <div class="acs-contact-form__field">
                  <label for="contact-email" class="acs-contact-form__label">Email *</label>
                  <input
                    type="email"
                    id="contact-email"
                    name="contact[email]"
                    class="acs-contact-form__input"
                    placeholder="you@example.com"
                    required
                    autocomplete="email"
                  >
                </div>
              </div>

              <div class="acs-contact-form__row">
                <div class="acs-contact-form__field">
                  <label for="contact-phone" class="acs-contact-form__label">Phone</label>
                  <input
                    type="tel"
                    id="contact-phone"
                    name="contact[phone]"
                    class="acs-contact-form__input"
                    placeholder="+91 98765 43210"
                    autocomplete="tel"
                  >
                </div>
                <div class="acs-contact-form__field">
                  <label for="contact-subject" class="acs-contact-form__label">Subject</label>
                  <select id="contact-subject" name="contact[subject]" class="acs-contact-form__select">
                    <option value="" disabled selected>Select a topic</option>
                    <option value="Order Help">Order Help</option>
                    <option value="Returns & Exchange">Returns & Exchange</option>
                    <option value="Product Question">Product Question</option>
                    <option value="Wholesale / Collaboration">Wholesale / Collaboration</option>
                    <option value="Feedback">Feedback</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
              </div>

              <div class="acs-contact-form__field">
                <label for="contact-message" class="acs-contact-form__label">Message *</label>
                <textarea
                  id="contact-message"
                  name="contact[body]"
                  class="acs-contact-form__textarea"
                  placeholder="Tell us how we can help..."
                  required
                ></textarea>
              </div>

              <button type="submit" class="acs-btn acs-btn--primary acs-contact-form__submit">
                {{ section.settings.submit_label }}
              </button>
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>

      {%- comment %} ---- INFO SIDEBAR ---- {%- endcomment -%}
      <div class="acs-contact-sidebar">
        <div class="acs-contact-info-card">
          <div class="acs-contact-info-item">
            <div class="acs-contact-info-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="acs-contact-info-text">
              <strong>Email</strong>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </div>
          </div>

          <div class="acs-contact-info-item">
            <div class="acs-contact-info-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div class="acs-contact-info-text">
              <strong>Phone</strong>
              <a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a>
            </div>
          </div>

          <div class="acs-contact-info-item">
            <div class="acs-contact-info-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="acs-contact-info-text">
              <strong>Hours</strong>
              <span>{{ section.settings.hours }}</span>
            </div>
          </div>

          <div class="acs-contact-info-item">
            <div class="acs-contact-info-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="acs-contact-info-text">
              <strong>Location</strong>
              <span>{{ section.settings.location }}</span>
            </div>
          </div>
        </div>

        {%- if section.settings.whatsapp_number != blank -%}
          <a href="https://wa.me/{{ section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}?text={{ section.settings.whatsapp_message | url_encode }}" target="_blank" rel="noopener" class="acs-contact-whatsapp">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Chat on WhatsApp
          </a>
        {%- endif -%}

        <div style="padding:var(--acs-space-lg);border:var(--acs-border-subtle);border-radius:var(--acs-radius-md);text-align:center;">
          <p class="acs-muted" style="font-size:var(--acs-type-small);margin:0 0 var(--acs-space-sm);">
            {{ section.settings.faq_text }}
          </p>
          <a href="{{ section.settings.faq_link | default: '/pages/faq' }}" class="acs-btn acs-btn--ghost" style="font-size:var(--acs-type-caption);">
            {{ section.settings.faq_label }}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "class": "acs-contact-form-section",
  "settings": [
    { "type": "text", "id": "form_title", "label": "Form heading", "default": "Send us a message" },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Send Message" },
    { "type": "text", "id": "success_heading", "label": "Success heading", "default": "Message sent!" },
    { "type": "text", "id": "success_body", "label": "Success body", "default": "Thank you for reaching out. We'll get back to you within 24 hours." },
    { "type": "header", "content": "Contact Information" },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@acharkhastory.com" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+91 98765 43210" },
    { "type": "text", "id": "hours", "label": "Hours", "default": "Mon-Sat, 10am-6pm IST" },
    { "type": "text", "id": "location", "label": "Location", "default": "Mumbai, India" },
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp number", "default": "+919876543210" },
    { "type": "text", "id": "whatsapp_message", "label": "WhatsApp prefill", "default": "Hi! I need help with my Acharkhastory order." },
    { "type": "header", "content": "FAQ Link" },
    { "type": "text", "id": "faq_text", "label": "FAQ teaser text", "default": "Looking for quick answers? Check our FAQ." },
    { "type": "text", "id": "faq_label", "label": "FAQ button label", "default": "View FAQ" },
    { "type": "url", "id": "faq_link", "label": "FAQ link" }
  ],
  "presets": [{ "name": "Contact Form" }]
}
{% endschema %}
