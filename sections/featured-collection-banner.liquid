{% comment %}
  Acharkhastory featured story banner.
  Editorial image plus narrative content for craft, collection, or artisan storytelling.
{% endcomment %}

{% liquid
  assign title = section.settings.title | strip
  assign description = section.settings.description | strip
  assign image = section.settings.image
  assign cta_link = section.settings.cta_link | default: routes.all_products_collection_url
%}

<section
  class="acs-featured-banner{% if section.settings.reverse_layout %} acs-featured-banner--reverse{% endif %}"
  id="FeaturedBanner-{{ section.id }}"
>
  <div class="acs-featured-banner__media">
    {%- if image != blank -%}
      <img
        src="{{ image | image_url: width: 1200 }}"
        srcset="{{ image | image_url: width: 720 }} 720w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1600 }} 1600w"
        sizes="(max-width: 768px) 100vw, 55vw"
        width="{{ image.width }}"
        height="{{ image.height }}"
        alt="{{ section.settings.image_alt | default: title | escape }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'collection-2' | placeholder_svg_tag }}
    {%- endif -%}
  </div>

  <div class="acs-featured-banner__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="acs-eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if title != blank -%}
      <h2 class="acs-featured-banner__title">{{ title | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.tagline != blank -%}
      <p class="acs-featured-banner__tagline">{{ section.settings.tagline | escape }}</p>
    {%- endif -%}

    {%- if description != blank -%}
      <p class="acs-featured-banner__text">{{ description | escape }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div>
        <a class="acs-button acs-button--light" href="{{ cta_link }}">
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "ACS Featured Banner",
  "tag": "section",
  "class": "shopify-section--acs-featured-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Indian artisan textile story"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured Story"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Clothing that tells a story"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "From our looms to your wardrobe"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Each piece is hand-blocked, hand-stitched, and finished by artisans who have inherited their craft across generations."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Image on right side",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "ACS Featured Banner"
    }
  ]
}
{% endschema %}
