{% comment %}
  ACHARKHASTORY — Featured Collection Banner
  Full-width 55/45 split with editorial image + content.
  Toggle image left/right via schema.
{% endcomment %}

{{ 'acharkhastory.css' | asset_url | stylesheet_tag }}

<style>
  .fcb {
    background: var(--acs-surface);
    overflow: hidden;
  }

  .fcb__inner {
    display: flex;
    align-items: stretch;
    min-height: 560px;
  }

  .fcb__inner--reversed {
    flex-direction: row-reverse;
  }

  .fcb__media {
    flex: 0 0 55%;
    position: relative;
    overflow: hidden;
  }

  .fcb__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--acs-ease);
  }

  .fcb:hover .fcb__media img {
    transform: scale(1.02);
  }

  .fcb__content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--acs-sp-3xl);
    gap: var(--acs-sp-md);
  }

  .fcb__eyebrow {
    font-family: var(--acs-font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--acs-secondary);
  }

  .fcb__title {
    font-family: var(--acs-font-display);
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 500;
    line-height: 1.15;
    color: var(--acs-primary);
    margin: 0;
  }

  .fcb__tagline {
    font-family: var(--acs-font-display);
    font-size: 18px;
    font-style: italic;
    color: var(--acs-text-muted);
    line-height: 1.5;
  }

  .fcb__description {
    font-family: var(--acs-font-body);
    font-size: var(--acs-fs-body);
    color: var(--acs-text);
    line-height: 1.8;
    max-width: 420px;
  }

  .fcb__cta {
    margin-top: var(--acs-sp-xs);
  }

  @media (max-width: 768px) {
    .fcb__inner,
    .fcb__inner--reversed {
      flex-direction: column;
    }

    .fcb__media {
      flex: none;
      height: 360px;
    }

    .fcb__content {
      flex: none;
      padding: var(--acs-sp-xl) var(--acs-edge-m);
      text-align: center;
      align-items: center;
    }

    .fcb__description {
      max-width: 100%;
    }
  }
</style>

<section class="fcb" id="fcb-{{ section.id }}">
  <div class="fcb__inner{% if section.settings.reverse_layout %} fcb__inner--reversed{% endif %}">
    <div class="fcb__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          srcset="
            {{ section.settings.image | image_url: width: 800 }} 800w,
            {{ section.settings.image | image_url: width: 1200 }} 1200w
          "
          sizes="(max-width: 768px) 100vw, 55vw"
          alt="{{ section.settings.title | escape }}"
          loading="lazy"
          width="1200"
          height="800"
        >
      {%- else -%}
        {{ 'collection-2' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    <div class="fcb__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="fcb__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h2 class="fcb__title">{{ section.settings.title }}</h2>

      {%- if section.settings.tagline != blank -%}
        <p class="fcb__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="fcb__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <div class="fcb__cta">
          <a href="{{ section.settings.cta_link }}" class="acs-btn acs-btn--primary">
            {{ section.settings.cta_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection Banner",
  "tag": "section",
  "class": "fcb-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Clothing that tells a story"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline (italic)",
      "default": "From our looms to your wardrobe"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Image on right side",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Banner"
    }
  ]
}
{% endschema %}
