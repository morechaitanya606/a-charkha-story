{% comment %}
  Acharkhastory hero banner slider.
  Full-bleed, image-first carousel for above-the-fold conversion.
{% endcomment %}

{% liquid
  assign aria_label = section.settings.aria_label | strip
  assign slide_label = section.settings.slide_label | strip
  assign dot_label = section.settings.dot_label | strip
  assign previous_label = section.settings.previous_label | strip
  assign next_label = section.settings.next_label | strip
  assign slide_count = section.blocks.size
  assign interval_ms = section.settings.interval | times: 1000
%}

{%- if slide_count > 0 -%}
  <section
    class="acs-hero hero-slider"
    id="HeroSlider-{{ section.id }}"
    {% if aria_label != blank %}
      aria-label="{{ aria_label | escape }}"
    {% endif %}
    aria-roledescription="carousel"
    data-hero-slider
    data-autoplay="{{ section.settings.autoplay }}"
    data-interval="{{ interval_ms }}"
    tabindex="0"
  >
    <div class="acs-hero__track hero-slider__track">
      {%- for block in section.blocks -%}
        {% liquid
          assign desktop_image = block.settings.desktop_image
          assign mobile_image = block.settings.mobile_image
          assign image_alt = block.settings.image_alt | default: block.settings.headline | strip
          assign image_focus = block.settings.image_focus | default: 'center center'
          assign primary_link = block.settings.cta1_link | default: routes.all_products_collection_url
          assign secondary_link = block.settings.cta2_link | default: routes.root_url
          assign loading = 'lazy'
          assign fetch_priority = 'auto'

          if forloop.first
            assign loading = 'eager'
            assign fetch_priority = 'high'
          endif
        %}

        <div
          class="acs-hero__slide hero-slider__slide{% if forloop.first %} is-active{% endif %}"
          id="HeroSlide-{{ section.id }}-{{ forloop.index }}"
          role="group"
          aria-roledescription="slide"
          aria-label="{{ slide_label | escape }} {{ forloop.index }} / {{ slide_count }}"
          {{ block.shopify_attributes }}
        >
          <div class="acs-hero__media hero-slider__media">
            {%- if desktop_image != blank or mobile_image != blank -%}
              <picture>
                {%- if mobile_image != blank -%}
                  <source
                    media="(max-width: 768px)"
                    srcset="{{ mobile_image | image_url: width: 480 }} 480w, {{ mobile_image | image_url: width: 800 }} 800w"
                    sizes="100vw"
                  >
                {%- endif -%}

                {%- if desktop_image != blank -%}
                  <img
                    src="{{ desktop_image | image_url: width: 1600 }}"
                    srcset="{{ desktop_image | image_url: width: 900 }} 900w, {{ desktop_image | image_url: width: 1400 }} 1400w, {{ desktop_image | image_url: width: 1800 }} 1800w"
                    sizes="100vw"
                    width="{{ desktop_image.width }}"
                    height="{{ desktop_image.height }}"
                    alt="{{ image_alt | escape }}"
                    loading="{{ loading }}"
                    {% if fetch_priority == 'high' %}
                      fetchpriority="high"
                    {% endif %}
                    style="object-position: {{ image_focus }};"
                  >
                {%- else -%}
                  <img
                    src="{{ mobile_image | image_url: width: 800 }}"
                    srcset="{{ mobile_image | image_url: width: 480 }} 480w, {{ mobile_image | image_url: width: 800 }} 800w"
                    sizes="100vw"
                    width="{{ mobile_image.width }}"
                    height="{{ mobile_image.height }}"
                    alt="{{ image_alt | escape }}"
                    loading="{{ loading }}"
                    {% if fetch_priority == 'high' %}
                      fetchpriority="high"
                    {% endif %}
                    style="object-position: {{ image_focus }};"
                  >
                {%- endif -%}
              </picture>
            {%- else -%}
              <div class="acs-hero__placeholder hero-slider__placeholder" aria-hidden="true"></div>
            {%- endif -%}
          </div>

          <div class="acs-hero__overlay hero-slider__overlay" aria-hidden="true"></div>

          <div class="acs-hero__content hero-slider__content">
            <div class="acs-hero__content-inner hero-slider__content-inner">
              {%- if block.settings.eyebrow != blank -%}
                <p class="acs-eyebrow acs-hero__eyebrow hero-slider__eyebrow">
                  {{ block.settings.eyebrow | escape }}
                </p>
              {%- endif -%}

              {%- if block.settings.headline != blank -%}
                {%- if forloop.first and section.settings.first_slide_h1 -%}
                  <h1 class="acs-hero__headline hero-slider__headline">
                    {{ block.settings.headline | escape }}
                  </h1>
                {%- else -%}
                  <h2 class="acs-hero__headline hero-slider__headline">
                    {{ block.settings.headline | escape }}
                  </h2>
                {%- endif -%}
              {%- endif -%}

              {%- if block.settings.subtext != blank -%}
                <p class="acs-hero__subtext hero-slider__subtext">
                  {{ block.settings.subtext | escape }}
                </p>
              {%- endif -%}

              <div class="acs-hero__ctas hero-slider__ctas">
                {%- if block.settings.cta1_label != blank -%}
                  <a href="{{ primary_link }}" class="acs-btn acs-btn--ivory hero-slider__cta">
                    {{ block.settings.cta1_label | escape }}
                  </a>
                {%- endif -%}

                {%- if block.settings.cta2_label != blank -%}
                  <a
                    href="{{ secondary_link }}"
                    class="acs-btn acs-btn--ghost-ivory hero-slider__cta hero-slider__cta--secondary"
                  >
                    {{ block.settings.cta2_label | escape }}
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if slide_count > 1 -%}
      <button
        class="acs-hero__arrow acs-hero__arrow--prev hero-slider__arrow hero-slider__arrow--prev"
        type="button"
        aria-label="{{ previous_label | escape }}"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>

      <button
        class="acs-hero__arrow acs-hero__arrow--next hero-slider__arrow hero-slider__arrow--next"
        type="button"
        aria-label="{{ next_label | escape }}"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M9 6l6 6-6 6"/>
        </svg>
      </button>

      <ol class="acs-hero__dots hero-slider__dots" role="tablist" aria-label="{{ dot_label | escape }}">
        {%- for block in section.blocks -%}
          <li>
            <button
              class="acs-hero__dot hero-slider__dot{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="HeroSlide-{{ section.id }}-{{ forloop.index }}"
              aria-label="{{ dot_label | escape }} {{ forloop.index }}"
              data-index="{{ forloop.index0 }}"
            ></button>
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </section>

  <script src="{{ 'hero-slider.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "ACS Hero Slider",
  "tag": "section",
  "class": "shopify-section--acs-hero",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessible label",
      "default": "Featured collections"
    },
    {
      "type": "checkbox",
      "id": "first_slide_h1",
      "label": "Use first slide headline as the page H1",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-advance slides",
      "default": true
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Seconds between slides",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "previous_label",
      "label": "Previous button label",
      "default": "Previous slide"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "Next button label",
      "default": "Next slide"
    },
    {
      "type": "text",
      "id": "slide_label",
      "label": "Slide label prefix",
      "default": "Slide"
    },
    {
      "type": "text",
      "id": "dot_label",
      "label": "Dot navigation label",
      "default": "Go to slide"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Handcrafted artisan fashion by Acharkhastory"
        },
        {
          "type": "select",
          "id": "image_focus",
          "label": "Image focus",
          "options": [
            {
              "value": "center center",
              "label": "Center"
            },
            {
              "value": "center top",
              "label": "Top"
            },
            {
              "value": "center bottom",
              "label": "Bottom"
            },
            {
              "value": "left center",
              "label": "Left"
            },
            {
              "value": "right center",
              "label": "Right"
            }
          ],
          "default": "center center"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "New collection"
        },
        {
          "type": "text",
          "id": "headline",
          "label": "Headline",
          "default": "Stories woven in every thread"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Handcrafted clothing, jewellery, and home pieces made by Indian artisans."
        },
        {
          "type": "text",
          "id": "cta1_label",
          "label": "Primary CTA label",
          "default": "Shop new arrivals"
        },
        {
          "type": "url",
          "id": "cta1_link",
          "label": "Primary CTA link"
        },
        {
          "type": "text",
          "id": "cta2_label",
          "label": "Secondary CTA label",
          "default": "Meet the artisans"
        },
        {
          "type": "url",
          "id": "cta2_link",
          "label": "Secondary CTA link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "ACS Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "New collection",
            "headline": "Stories woven in every thread",
            "subtext": "Handcrafted Ajrakh clothing made by Indian artisans.",
            "cta1_label": "Shop new arrivals",
            "cta2_label": "Meet the artisans"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Craft focus",
            "headline": "Ajrakh, block printed by hand",
            "subtext": "Natural dyes, slow processes, and patterns rooted in Kutch.",
            "cta1_label": "Shop Ajrakh",
            "cta2_label": "Explore craft stories"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Heirloom embroidery",
            "headline": "Mirror work with a modern ease",
            "subtext": "Statement pieces made for celebrations, gifting, and everyday joy.",
            "cta1_label": "Shop embroidery",
            "cta2_label": "See the details"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Home and gifting",
            "headline": "Handmade warmth for the home",
            "subtext": "Textiles and gifts that carry the mark of the maker.",
            "cta1_label": "Shop home",
            "cta2_label": "Browse gifts"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Small batch drops",
            "headline": "Fresh arrivals before they sell out",
            "subtext": "Limited runs, mindful materials, and no mass production.",
            "cta1_label": "Shop latest",
            "cta2_label": "View bestsellers"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Made with meaning",
            "headline": "Your order supports artisan livelihoods",
            "subtext": "Each purchase helps keep handmade Indian craft in motion.",
            "cta1_label": "Shop with impact",
            "cta2_label": "Our story"
          }
        }
      ]
    }
  ]
}
{% endschema %}
