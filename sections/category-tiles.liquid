{% comment %}
  Acharkhastory category tiles.
  Fast shopping shortcuts for users who already know what they want.
{% endcomment %}

{% liquid
  assign heading = section.settings.title | strip
  assign subtitle = section.settings.subtitle | strip
  assign has_tiles = false

  for block in section.blocks
    assign label = block.settings.label | strip
    assign collection = block.settings.collection

    if label != blank or collection != blank
      assign has_tiles = true
      break
    endif
  endfor
%}

{%- if has_tiles -%}
  <section class="acs-section acs-category-tiles" id="CategoryTiles-{{ section.id }}">
    <div class="acs-container">
      {%- if heading != blank or subtitle != blank -%}
        <header class="acs-section-header acs-section-header--center">
          {%- if heading != blank -%}
            <h2 class="acs-h2">{{ heading | escape }}</h2>
          {%- endif -%}

          {%- if subtitle != blank -%}
            <p class="acs-section-header__subtitle">{{ subtitle | escape }}</p>
          {%- endif -%}
        </header>
      {%- endif -%}

      <div class="acs-category-tiles__grid">
        {%- for block in section.blocks -%}
          {% liquid
            assign collection = block.settings.collection
            assign label = block.settings.label | strip
            assign meta = block.settings.meta | strip
            assign image = block.settings.image
            assign link = block.settings.link
            assign image_alt = block.settings.image_alt | strip

            if label == blank and collection != blank
              assign label = collection.title
            endif

            if meta == blank and collection != blank
              assign meta = collection.all_products_count | append: ' pieces'
            endif

            if image == blank and collection.featured_image != blank
              assign image = collection.featured_image
            endif

            if image == blank and collection.image != blank
              assign image = collection.image
            endif

            if link == blank and collection != blank
              assign link = collection.url
            endif

            if link == blank
              assign link = routes.all_products_collection_url
            endif

            if image_alt == blank
              assign image_alt = label
            endif
          %}

          {%- if label != blank -%}
            <a class="acs-category-tile acs-card-lift acs-reveal" href="{{ link }}" data-acs-delay="{{ forloop.index }}" {{ block.shopify_attributes }}>
              <span class="acs-category-tile__image" aria-hidden="true">
                {%- if image != blank -%}
                  <img
                    src="{{ image | image_url: width: 600 }}"
                    srcset="{{ image | image_url: width: 360 }} 360w, {{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w"
                    sizes="(max-width: 768px) 50vw, 25vw"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                    alt="{{ image_alt | escape }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag }}
                {%- endif -%}
              </span>

              <span class="acs-category-tile__content">
                <span class="acs-category-tile__title">{{ label | escape }}</span>

                {%- if meta != blank -%}
                  <span class="acs-category-tile__meta">{{ meta | escape }}</span>
                {%- endif -%}
              </span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "ACS Category Tiles",
  "tag": "section",
  "class": "shopify-section--acs-category-tiles",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find the craft, silhouette, or gift you came for."
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Handmade Indian artisan collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Small supporting text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Override link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "ACS Category Tiles",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "label": "Clothing",
            "meta": "Kurtas, dresses, and layers"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Kurtas",
            "meta": "Handcrafted everyday staples"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Sarees",
            "meta": "Drapes with craft heritage"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Accessories",
            "meta": "Jewellery, bags, and accents"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Home",
            "meta": "Textiles and handmade gifts"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Sale",
            "meta": "Limited pieces, better prices"
          }
        }
      ]
    }
  ]
}
{% endschema %}
