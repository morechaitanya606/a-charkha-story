{% comment %}
  Acharkhastory customer reviews.
  Manual review cards with optional Judge.me app widget container.
{% endcomment %}

{% liquid
  assign heading = section.settings.title | strip
  assign subtitle = section.settings.subtitle | strip
  assign has_reviews = false

  for block in section.blocks
    if block.settings.review_text != blank
      assign has_reviews = true
      break
    endif
  endfor
%}

{%- if has_reviews or section.settings.enable_judgeme -%}
  <section class="acs-section acs-reviews" id="Reviews-{{ section.id }}">
    <div class="acs-container">
      {%- if heading != blank or subtitle != blank -%}
        <header class="acs-section-header acs-section-header--center">
          {%- if heading != blank -%}
            <h2 class="acs-h2">{{ heading | escape }}</h2>
          {%- endif -%}

          {%- if subtitle != blank -%}
            <p class="acs-section-header__subtitle">{{ subtitle | escape }}</p>
          {%- endif -%}
        </header>
      {%- endif -%}

      {%- if section.settings.enable_judgeme -%}
        <div class="jdgm-widget jdgm-review-widget"></div>
      {%- endif -%}

      {%- if has_reviews -%}
        <div class="acs-reviews__grid">
          {%- for block in section.blocks -%}
            {%- if block.settings.review_text != blank -%}
              <article class="acs-review-card" {{ block.shopify_attributes }}>
                <div class="acs-review-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {%- for index in (1..5) -%}
                    {%- if index <= block.settings.rating -%}&#9733;{%- else -%}&#9734;{%- endif -%}
                  {%- endfor -%}
                </div>

                <blockquote class="acs-review-card__quote">
                  {{ block.settings.review_text | escape }}
                </blockquote>

                <div>
                  <div class="acs-review-card__author">{{ block.settings.name | escape }}</div>
                  <div class="acs-review-card__meta">
                    {%- if block.settings.location != blank -%}
                      <span>{{ block.settings.location | escape }}</span>
                    {%- endif -%}
                    {%- if block.settings.verified_label != blank -%}
                      <span>{{ block.settings.verified_label | escape }}</span>
                    {%- endif -%}
                  </div>
                </div>

                {%- if block.settings.product_name != blank -%}
                  <div class="acs-review-card__product">
                    {{ section.settings.purchased_prefix | escape }} {{ block.settings.product_name | escape }}
                  </div>
                {%- endif -%}
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "ACS Reviews",
  "tag": "section",
  "class": "shopify-section--acs-reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Our Community Says"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real stories from real customers."
    },
    {
      "type": "checkbox",
      "id": "enable_judgeme",
      "label": "Show Judge.me widget container",
      "default": false,
      "info": "Install Judge.me and enable its app embed before turning this on."
    },
    {
      "type": "text",
      "id": "purchased_prefix",
      "label": "Purchased product prefix",
      "default": "Purchased:"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Priya S."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Mumbai"
        },
        {
          "type": "text",
          "id": "verified_label",
          "label": "Verified label",
          "default": "Verified purchase"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "The Ajrakh kurta is stunning. The natural dyes give it such a rich, earthy tone. I can feel the craft in every stitch."
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product purchased",
          "default": "Ajrakh Block Print Kurta"
        }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "ACS Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "name": "Priya S.",
            "location": "Mumbai",
            "rating": 5,
            "review_text": "The Ajrakh kurta is stunning. The natural dyes give it such a rich, earthy tone. I can feel the craft in every stitch.",
            "product_name": "Ajrakh Block Print Kurta"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Ananya R.",
            "location": "Bangalore",
            "rating": 5,
            "review_text": "Ordered the mirror work dupatta and it is absolutely gorgeous. The packaging was beautiful too and felt like receiving a gift.",
            "product_name": "Kutchi Mirror Work Dupatta"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Meera K.",
            "location": "Delhi",
            "rating": 4,
            "review_text": "Love that each piece comes with a note about the artisan who made it. The chikankari top is my new favourite for office wear.",
            "product_name": "Chikankari Cotton Top"
          }
        }
      ]
    }
  ]
}
{% endschema %}
