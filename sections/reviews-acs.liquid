{% comment %}
  ACHARKHASTORY — Customer Reviews
  3-column review cards. Integrates Judge.me embed.
  Includes manual review blocks as fallback / seed content.
{% endcomment %}

{{ 'acharkhastory.css' | asset_url | stylesheet_tag }}

<style>
  .reviews-acs {
    padding-block: var(--acs-section-py);
    background: var(--acs-cream);
  }

  .reviews-acs__inner {
    max-width: var(--acs-container);
    margin-inline: auto;
    padding-inline: var(--acs-edge);
  }

  .reviews-acs__header {
    text-align: center;
    margin-bottom: var(--acs-sp-xl);
  }

  .reviews-acs__title {
    font-family: var(--acs-font-display);
    font-size: var(--acs-fs-h2);
    font-weight: 500;
    color: var(--acs-primary);
    margin: 0;
  }

  .reviews-acs__subtitle {
    font-family: var(--acs-font-body);
    font-size: 14px;
    color: var(--acs-text-muted);
    margin-top: var(--acs-sp-xs);
  }

  /* Judge.me embed container */
  .reviews-acs__judgeme {
    margin-bottom: var(--acs-sp-xl);
  }

  /* Manual review cards */
  .reviews-acs__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--acs-sp-lg);
  }

  .reviews-acs__card {
    background: var(--acs-white);
    border-radius: var(--acs-r-md);
    padding: var(--acs-sp-lg);
    display: flex;
    flex-direction: column;
    gap: var(--acs-sp-sm);
  }

  .reviews-acs__card-header {
    display: flex;
    align-items: center;
    gap: var(--acs-sp-sm);
  }

  .reviews-acs__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--acs-surface);
    flex-shrink: 0;
  }

  .reviews-acs__avatar--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--acs-font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--acs-secondary);
    background: var(--acs-surface);
  }

  .reviews-acs__author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .reviews-acs__name {
    font-family: var(--acs-font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--acs-primary);
  }

  .reviews-acs__location {
    font-family: var(--acs-font-body);
    font-size: 11px;
    color: var(--acs-text-muted);
  }

  .reviews-acs__stars {
    color: var(--acs-warm-mid);
    font-size: 14px;
    letter-spacing: 2px;
    line-height: 1;
  }

  .reviews-acs__text {
    font-family: var(--acs-font-body);
    font-size: 14px;
    color: var(--acs-text);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .reviews-acs__product {
    font-family: var(--acs-font-body);
    font-size: 11px;
    color: var(--acs-text-muted);
    font-style: italic;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .reviews-acs__grid {
      grid-template-columns: 1fr;
      gap: var(--acs-sp-md);
      display: flex;
      overflow-x: auto;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .reviews-acs__grid::-webkit-scrollbar {
      display: none;
    }

    .reviews-acs__card {
      min-width: 280px;
      flex-shrink: 0;
    }
  }
</style>

<section class="reviews-acs" id="reviews-acs-{{ section.id }}">
  <div class="reviews-acs__inner">
    <div class="reviews-acs__header">
      <h2 class="reviews-acs__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="reviews-acs__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Judge.me widget embed — will render when app is installed {%- endcomment -%}
    {%- if section.settings.enable_judgeme -%}
      <div class="reviews-acs__judgeme">
        <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget"></div>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="reviews-acs__grid">
        {%- for block in section.blocks -%}
          <div class="reviews-acs__card" {{ block.shopify_attributes }}>
            <div class="reviews-acs__card-header">
              {%- if block.settings.avatar != blank -%}
                <img
                  class="reviews-acs__avatar"
                  src="{{ block.settings.avatar | image_url: width: 96 }}"
                  alt="{{ block.settings.name }}"
                  loading="lazy"
                  width="48"
                  height="48"
                >
              {%- else -%}
                <div class="reviews-acs__avatar reviews-acs__avatar--placeholder">
                  {{ block.settings.name | slice: 0 }}
                </div>
              {%- endif -%}
              <div class="reviews-acs__author">
                <span class="reviews-acs__name">{{ block.settings.name }}</span>
                {%- if block.settings.location != blank -%}
                  <span class="reviews-acs__location">{{ block.settings.location }}</span>
                {%- endif -%}
              </div>
            </div>

            <div class="reviews-acs__stars">
              {%- assign star_count = block.settings.rating | default: 5 -%}
              {%- for i in (1..5) -%}
                {%- if i <= star_count -%}★{%- else -%}☆{%- endif -%}
              {%- endfor -%}
            </div>

            <p class="reviews-acs__text">{{ block.settings.review_text }}</p>

            {%- if block.settings.product_name != blank -%}
              <span class="reviews-acs__product">Purchased: {{ block.settings.product_name }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "reviews-acs-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Our Community Says"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Real stories from real customers"
    },
    {
      "type": "checkbox",
      "id": "enable_judgeme",
      "label": "Enable Judge.me widget",
      "default": false,
      "info": "Install the Judge.me app from Shopify to enable dynamic reviews"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Priya S."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Mumbai"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Photo (optional)"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "The Ajrakh kurta is stunning. The natural dyes give it such a rich, earthy tone. I can feel the craft in every stitch."
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product purchased",
          "default": "Ajrakh Block Print Kurta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "name": "Priya S.",
            "location": "Mumbai",
            "rating": 5,
            "review_text": "The Ajrakh kurta is stunning. The natural dyes give it such a rich, earthy tone. I can feel the craft in every stitch.",
            "product_name": "Ajrakh Block Print Kurta"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Ananya R.",
            "location": "Bangalore",
            "rating": 5,
            "review_text": "Ordered the mirror work dupatta and it's absolutely gorgeous. The packaging was beautiful too — felt like receiving a gift.",
            "product_name": "Kutchi Mirror Work Dupatta"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Meera K.",
            "location": "Delhi",
            "rating": 4,
            "review_text": "Love that each piece comes with a note about the artisan who made it. The chikankari top is my new favourite for office wear.",
            "product_name": "Chikankari Cotton Top"
          }
        }
      ]
    }
  ],
  "max_blocks": 9
}
{% endschema %}
