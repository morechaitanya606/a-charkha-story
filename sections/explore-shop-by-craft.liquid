{% comment %}
  ACHARKHASTORY — Shop By Craft (EX4)
  Inline previews of collections (Craft name/desc on left, 3 products on right).
{% endcomment %}

{{ 'acharkhastory.css' | asset_url | stylesheet_tag }}

<style>
  .explore-shop {
    max-width: var(--acs-container);
    margin-inline: auto;
    padding-inline: var(--acs-edge);
    padding-block: var(--acs-section-py);
  }

  .explore-shop__row {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: var(--acs-sp-2xl);
    margin-bottom: var(--acs-sp-4xl);
  }

  .explore-shop__row:last-child {
    margin-bottom: 0;
  }

  /* Left: Craft Info */
  .explore-shop__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .explore-shop__title {
    font-family: var(--acs-font-display);
    font-size: 24px;
    font-weight: 500;
    color: var(--acs-primary);
    margin: 0 0 var(--acs-sp-xxs);
  }

  .explore-shop__region {
    font-family: var(--acs-font-body);
    font-size: 12px;
    color: var(--acs-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--acs-sp-md);
  }

  .explore-shop__desc {
    font-family: var(--acs-font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--acs-text);
    margin: 0 0 var(--acs-sp-lg);
  }

  .explore-shop__link {
    font-family: var(--acs-font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--acs-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .explore-shop__link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* Right: Products Grid */
  .explore-shop__products {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--acs-gutter);
  }

  @media (max-width: 1024px) {
    .explore-shop__row {
      grid-template-columns: 1fr 2fr;
    }
    .explore-shop__products {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .explore-shop__row {
      grid-template-columns: 1fr;
      gap: var(--acs-sp-md);
      margin-bottom: var(--acs-sp-2xl);
    }
    .explore-shop__products {
      display: flex;
      overflow-x: auto;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: var(--acs-sp-md);
      margin-inline: calc(-1 * var(--acs-edge-m));
      padding-inline: var(--acs-edge-m);
      gap: 16px;
    }
    .explore-shop__products::-webkit-scrollbar {
      display: none;
    }
    .explore-shop__products > * {
      min-width: 240px;
      flex-shrink: 0;
    }
  }
</style>

<section class="explore-shop" id="explore-shop">
  {%- for block in section.blocks -%}
    {%- assign collection = block.settings.collection -%}
    <div class="explore-shop__row" {{ block.shopify_attributes }}>
      <div class="explore-shop__info">
        <h2 class="explore-shop__title">{{ block.settings.title | default: collection.title }}</h2>
        {%- if block.settings.region != blank -%}
          <p class="explore-shop__region">{{ block.settings.region }}</p>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <p class="explore-shop__desc">{{ block.settings.description }}</p>
        {%- endif -%}
        <a href="{{ collection.url | default: '#' }}" class="explore-shop__link">
          Shop all {{ block.settings.title | default: collection.title }} &rarr;
        </a>
      </div>
      
      <div class="explore-shop__products">
        {%- if collection != blank and collection.products_count > 0 -%}
          {%- for product in collection.products limit: 3 -%}
            {% render 'product-card-acs', product: product %}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..3) -%}
            <div class="acs-card">
              <div style="aspect-ratio: 3/4; background: var(--acs-surface); display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--acs-border);">
                {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div style="padding: 16px;">
                <div style="font-family: var(--acs-font-body); font-size: 14px; font-weight: 500;">Example Product {{ i }}</div>
                <div style="font-family: var(--acs-font-body); font-size: 13px; color: var(--acs-text-muted); margin-top: 4px;">₹2,499</div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Shop by Craft",
  "tag": "section",
  "class": "explore-shop-section",
  "settings": [],
  "blocks": [
    {
      "type": "craft_collection",
      "name": "Craft Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection to display"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Craft Name Override"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Region Label",
          "default": "Kutch, Gujarat"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short Description",
          "default": "A centuries-old block printing technique using natural dyes and complex geometric patterns."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Craft",
      "blocks": [
        { "type": "craft_collection", "settings": { "title": "Ajrakh", "region": "Kutch, Gujarat & Sindh" } },
        { "type": "craft_collection", "settings": { "title": "Chikankari", "region": "Lucknow, UP" } }
      ]
    }
  ]
}
{% endschema %}
