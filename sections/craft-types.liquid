{% comment %}
  ACHARKHASTORY — Shop by Craft
  Horizontal scroll of craft type cards (200×280px portrait).
  Dark gradient overlay, name bottom-left, hover scale.
{% endcomment %}

{{ 'acharkhastory.css' | asset_url | stylesheet_tag }}

<style>
  .craft-types {
    padding-block: var(--acs-section-py);
    background: var(--acs-bg);
    overflow: hidden;
  }

  .craft-types__inner {
    max-width: var(--acs-container);
    margin-inline: auto;
    padding-inline: var(--acs-edge);
  }

  .craft-types__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--acs-sp-lg);
  }

  .craft-types__title {
    font-family: var(--acs-font-display);
    font-size: var(--acs-fs-h2);
    font-weight: 500;
    color: var(--acs-primary);
    margin: 0;
  }

  .craft-types__explore {
    font-family: var(--acs-font-body);
    font-size: var(--acs-fs-nav);
    color: var(--acs-secondary);
    text-decoration: none;
  }

  .craft-types__explore:hover {
    text-decoration: underline;
  }

  .craft-types__track {
    display: flex;
    gap: var(--acs-sp-md);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--acs-sp-xs);
  }

  .craft-types__track::-webkit-scrollbar {
    display: none;
  }

  .craft-types__card {
    flex: 0 0 200px;
    height: 280px;
    position: relative;
    border-radius: var(--acs-r-lg);
    overflow: hidden;
    text-decoration: none;
    display: block;
    cursor: pointer;
  }

  .craft-types__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--acs-ease);
  }

  .craft-types__card:hover img {
    transform: scale(1.03);
  }

  .craft-types__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26, 16, 8, 0.6) 0%, transparent 50%);
  }

  .craft-types__info {
    position: absolute;
    bottom: var(--acs-sp-md);
    left: var(--acs-sp-md);
    z-index: 1;
  }

  .craft-types__name {
    font-family: var(--acs-font-body);
    font-size: var(--acs-fs-nav);
    font-weight: 500;
    text-transform: uppercase;
    color: var(--acs-ivory);
    letter-spacing: 0.04em;
  }

  .craft-types__region {
    font-family: var(--acs-font-body);
    font-size: 11px;
    color: rgba(253, 246, 238, 0.7);
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .craft-types__card {
      flex: 0 0 160px;
      height: 220px;
    }

    .craft-types__header {
      flex-direction: column;
      gap: var(--acs-sp-xs);
    }
  }
</style>

<section class="craft-types" id="craft-types-{{ section.id }}">
  <div class="craft-types__inner">
    <div class="craft-types__header">
      <h2 class="craft-types__title">{{ section.settings.title }}</h2>
      {%- if section.settings.explore_link != blank -%}
        <a href="{{ section.settings.explore_link }}" class="craft-types__explore">
          {{ section.settings.explore_text | default: 'Explore all crafts →' }}
        </a>
      {%- endif -%}
    </div>

    <div class="craft-types__track">
      {%- for block in section.blocks -%}
        <a class="craft-types__card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.name | escape }}"
              loading="lazy"
              width="400"
              height="560"
            >
          {%- else -%}
            {{ 'collection-3' | placeholder_svg_tag }}
          {%- endif -%}
          <div class="craft-types__gradient"></div>
          <div class="craft-types__info">
            <div class="craft-types__name">{{ block.settings.name }}</div>
            {%- if block.settings.region != blank -%}
              <div class="craft-types__region">{{ block.settings.region }}</div>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Craft Types",
  "tag": "section",
  "class": "craft-types-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Craft"
    },
    {
      "type": "text",
      "id": "explore_text",
      "label": "Explore link text",
      "default": "Explore all crafts →"
    },
    {
      "type": "url",
      "id": "explore_link",
      "label": "Explore link"
    }
  ],
  "blocks": [
    {
      "type": "craft",
      "name": "Craft",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Craft name",
          "default": "Ajrakh"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Region",
          "default": "Kutch, Gujarat"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Craft Types",
      "blocks": [
        { "type": "craft", "settings": { "name": "Ajrakh", "region": "Kutch, Gujarat" } },
        { "type": "craft", "settings": { "name": "Block Printing", "region": "Rajasthan" } },
        { "type": "craft", "settings": { "name": "Chikankari", "region": "Lucknow, UP" } },
        { "type": "craft", "settings": { "name": "Mirror Work", "region": "Kutch, Gujarat" } },
        { "type": "craft", "settings": { "name": "Kalamkari", "region": "Andhra Pradesh" } },
        { "type": "craft", "settings": { "name": "Ikat", "region": "Odisha & Telangana" } }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
