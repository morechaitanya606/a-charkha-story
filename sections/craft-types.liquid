{% comment %}
  Acharkhastory shop by craft.
  Discovery grid for undecided buyers who shop by textile technique.
{% endcomment %}

{% liquid
  assign heading = section.settings.title | strip
  assign subtitle = section.settings.subtitle | strip
  assign has_crafts = false

  for block in section.blocks
    assign craft_name = block.settings.name | strip

    if craft_name != blank
      assign has_crafts = true
      break
    endif
  endfor
%}

{%- if has_crafts -%}
  <section class="acs-section acs-craft-grid" id="CraftTypes-{{ section.id }}">
    <div class="acs-container">
      <header class="acs-product-carousel__header">
        <div class="acs-section-header">
          {%- if heading != blank -%}
            <h2 class="acs-h2">{{ heading | escape }}</h2>
          {%- endif -%}

          {%- if subtitle != blank -%}
            <p class="acs-section-header__subtitle">{{ subtitle | escape }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.explore_text != blank and section.settings.explore_link != blank -%}
          <a class="acs-button acs-button--link" href="{{ section.settings.explore_link }}">
            {{ section.settings.explore_text | escape }}
          </a>
        {%- endif -%}
      </header>

      <div class="acs-craft-grid__items">
        {%- for block in section.blocks -%}
          {% liquid
            assign craft_name = block.settings.name | strip
            assign region = block.settings.region | strip
            assign image = block.settings.image
            assign link = block.settings.link | default: routes.all_products_collection_url
          %}

          {%- if craft_name != blank -%}
            <a class="acs-craft-card" href="{{ link }}" {{ block.shopify_attributes }}>
              <span class="acs-craft-card__media">
                {%- if image != blank -%}
                  <img
                    src="{{ image | image_url: width: 420 }}"
                    srcset="{{ image | image_url: width: 240 }} 240w, {{ image | image_url: width: 420 }} 420w, {{ image | image_url: width: 640 }} 640w"
                    sizes="(max-width: 768px) 50vw, 20vw"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                    alt="{{ block.settings.image_alt | default: craft_name | escape }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'collection-3' | placeholder_svg_tag }}
                {%- endif -%}
              </span>

              <span>
                <span class="acs-craft-card__title">{{ craft_name | escape }}</span>
                {%- if region != blank -%}
                  <span class="acs-craft-card__meta">{{ region | escape }}</span>
                {%- endif -%}
              </span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "ACS Craft Types",
  "tag": "section",
  "class": "shopify-section--acs-craft-types",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Craft"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Choose by technique, region, and the story behind the piece."
    },
    {
      "type": "text",
      "id": "explore_text",
      "label": "Explore link text",
      "default": "Explore all crafts"
    },
    {
      "type": "url",
      "id": "explore_link",
      "label": "Explore link"
    }
  ],
  "blocks": [
    {
      "type": "craft",
      "name": "Craft",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Craft name",
          "default": "Ajrakh"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Region",
          "default": "Kutch, Gujarat"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "ACS Craft Types",
      "blocks": [
        {
          "type": "craft",
          "settings": {
            "name": "Ajrakh",
            "region": "Kutch, Gujarat"
          }
        },
        {
          "type": "craft",
          "settings": {
            "name": "Block Printing",
            "region": "Rajasthan"
          }
        },
        {
          "type": "craft",
          "settings": {
            "name": "Chikankari",
            "region": "Lucknow, Uttar Pradesh"
          }
        },
        {
          "type": "craft",
          "settings": {
            "name": "Mirror Work",
            "region": "Kutch, Gujarat"
          }
        },
        {
          "type": "craft",
          "settings": {
            "name": "Kalamkari",
            "region": "Andhra Pradesh"
          }
        },
        {
          "type": "craft",
          "settings": {
            "name": "Ikat",
            "region": "Odisha and Telangana"
          }
        }
      ]
    }
  ]
}
{% endschema %}
