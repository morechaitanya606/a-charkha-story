{% comment %}
  Acharkhastory PDP reviews section.
  Uses a Judge.me widget container when enabled and manual review cards as a fallback.
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading | default: 'Community Reviews'
  assign max_manual = section.settings.max_manual | default: 6
  assign total_reviews = 0
  assign total_rating = 0
  assign count_5 = 0
  assign count_4 = 0
  assign count_3 = 0
  assign count_2 = 0
  assign count_1 = 0

  for block in section.blocks limit: max_manual
    assign rating = block.settings.rating | default: 5
    assign total_reviews = total_reviews | plus: 1
    assign total_rating = total_rating | plus: rating

    case rating
      when 5
        assign count_5 = count_5 | plus: 1
      when 4
        assign count_4 = count_4 | plus: 1
      when 3
        assign count_3 = count_3 | plus: 1
      when 2
        assign count_2 = count_2 | plus: 1
      else
        assign count_1 = count_1 | plus: 1
    endcase
  endfor

  assign average_rating = 0
  if total_reviews > 0
    assign average_rating = total_rating | times: 10 | divided_by: total_reviews | divided_by: 10.0
  endif
-%}

<section class="acs-product-reviews" id="ProductReviews">
  <div class="acs-container">
    <header class="acs-product-reviews__header">
      <h2 class="acs-product-reviews__heading">{{ heading | escape }}</h2>
      {%- if total_reviews > 0 -%}
        <div class="acs-product-reviews__summary">
          <span class="acs-product-reviews__stars" aria-label="{{ average_rating }} out of 5 stars">
            {%- for index in (1..5) -%}
              {%- if index <= average_rating -%}&#9733;{%- else -%}&#9734;{%- endif -%}
            {%- endfor -%}
          </span>
          <span>{{ average_rating }} out of 5</span>
          <span>Based on {{ total_reviews }} reviews</span>
        </div>
      {%- endif -%}
    </header>

    {%- if section.settings.show_judgeme -%}
      <div
        class="jdgm-widget jdgm-review-widget acs-product-reviews__judgeme"
        data-product-title="{{ product.title | escape }}"
        data-id="{{ product.id }}"
      ></div>
    {%- endif -%}

    {%- if total_reviews > 0 -%}
      <div class="acs-product-reviews__overview">
        <div class="acs-product-reviews__breakdown" aria-label="Rating breakdown">
          {%- assign rating_rows = '5,4,3,2,1' | split: ',' -%}
          {%- for row in rating_rows -%}
            {%- liquid
              assign row_count = count_1
              if row == '5'
                assign row_count = count_5
              elsif row == '4'
                assign row_count = count_4
              elsif row == '3'
                assign row_count = count_3
              elsif row == '2'
                assign row_count = count_2
              endif

              assign row_percent = 0
              if total_reviews > 0
                assign row_percent = row_count | times: 100 | divided_by: total_reviews
              endif
            -%}
            <div class="acs-product-reviews__bar-row">
              <span>{{ row }} star</span>
              <span class="acs-product-reviews__bar" aria-hidden="true">
                <span class="acs-product-reviews__bar-fill" data-rating-bar style="--acs-rating-width: {{ row_percent }}%;"></span>
              </span>
              <span>{{ row_count }}</span>
            </div>
          {%- endfor -%}
        </div>

        <div class="acs-product-reviews__filters" aria-label="Review filters">
          <label>
            <span>Filter</span>
            <select>
              <option>Most Recent</option>
              <option>Highest Rated</option>
              <option>Lowest Rated</option>
            </select>
          </label>
          <label class="acs-product-reviews__photo-filter">
            <input type="checkbox">
            With Photos
          </label>
        </div>
      </div>

      <div class="acs-product-reviews__grid">
        {%- for block in section.blocks limit: max_manual -%}
          <article class="acs-product-review-card" {{ block.shopify_attributes }}>
            <div class="acs-product-review-card__avatar">
              {%- if block.settings.reviewer_photo != blank -%}
                <img
                  src="{{ block.settings.reviewer_photo | image_url: width: 96 }}"
                  alt="{{ block.settings.reviewer_name | escape }}"
                  width="48"
                  height="48"
                  loading="lazy"
                >
              {%- else -%}
                <span>{{ block.settings.reviewer_name | default: 'A' | slice: 0 | upcase }}</span>
              {%- endif -%}
            </div>

            <div class="acs-product-review-card__body">
              <div class="acs-product-review-card__topline">
                <strong>{{ block.settings.reviewer_name | escape }}</strong>
                {%- if block.settings.reviewer_city != blank -%}
                  <span>{{ block.settings.reviewer_city | escape }}</span>
                {%- endif -%}
              </div>

              <div class="acs-product-review-card__meta">
                <span class="acs-product-review-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {%- for index in (1..5) -%}
                    {%- if index <= block.settings.rating -%}&#9733;{%- else -%}&#9734;{%- endif -%}
                  {%- endfor -%}
                </span>
                {%- if block.settings.review_date != blank -%}
                  <span>{{ block.settings.review_date | escape }}</span>
                {%- endif -%}
                <span>Verified purchase</span>
              </div>

              {%- if block.settings.review_text != blank -%}
                <blockquote>{{ block.settings.review_text | escape }}</blockquote>
              {%- endif -%}

              {%- if block.settings.variant_bought != blank -%}
                <p class="acs-product-review-card__variant">Variant: {{ block.settings.variant_bought | escape }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

      <div class="acs-product-reviews__actions">
        <button type="button" class="acs-btn acs-btn--ghost">Load more reviews</button>
        <button type="button" class="acs-btn acs-btn--primary">Write a review</button>
      </div>
    {%- elsif section.settings.show_judgeme == false -%}
      <div class="acs-product-reviews__empty">
        Reviews will appear here once customers start sharing their experience.
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "class": "shopify-section--product-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Community Reviews"
    },
    {
      "type": "checkbox",
      "id": "show_judgeme",
      "label": "Use Judge.me widget container",
      "default": true,
      "info": "Install and enable Judge.me before relying on this widget."
    },
    {
      "type": "number",
      "id": "max_manual",
      "label": "Max manual reviews to show",
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Name",
          "default": "Priya M."
        },
        {
          "type": "text",
          "id": "reviewer_city",
          "label": "City",
          "default": "Mumbai"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Absolutely beautiful. The craft detail is even richer in person and the fit feels easy for daily wear."
        },
        {
          "type": "text",
          "id": "review_date",
          "label": "Review date",
          "default": "15 May 2025"
        },
        {
          "type": "text",
          "id": "variant_bought",
          "label": "Variant bought",
          "default": "Size M / Indigo Blue"
        },
        {
          "type": "image_picker",
          "id": "reviewer_photo",
          "label": "Reviewer photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Reviews",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Ananya R.",
            "reviewer_city": "Bengaluru",
            "rating": 5,
            "review_text": "The handmade finish makes it feel special without being delicate. I wore it all day and it was comfortable.",
            "variant_bought": "Size S / Madder"
          }
        }
      ]
    }
  ]
}
{% endschema %}
