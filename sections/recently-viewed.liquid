{% comment %}
  Acharkhastory — Recently Viewed Products
  Horizontal scroll strip rendered dynamically via JS.
  Add to PDP or collection templates.
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading | default: 'Recently Viewed'
  assign exclude_handle = ''
  if product
    assign exclude_handle = product.handle
  endif
-%}

<section
  class="acs-rv acs-section"
  data-acs-recently-viewed
  data-exclude-handle="{{ exclude_handle }}"
  hidden
  id="RecentlyViewed-{{ section.id }}"
>
  <div class="acs-page-width">
    <h2 class="acs-rv__heading">{{ heading | escape }}</h2>
    <div class="acs-rv__grid" data-acs-rv-grid></div>
  </div>
</section>

<style>
  .acs-rv {
    padding-block: var(--acs-space-2xl);
    background: var(--acs-color-background);
  }

  .acs-rv__heading {
    font-family: var(--acs-font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    color: var(--acs-color-primary);
    margin: 0 0 var(--acs-space-lg);
  }

  .acs-rv__grid {
    display: flex;
    gap: var(--acs-space-md);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding-bottom: var(--acs-space-xs);
  }

  .acs-rv__grid::-webkit-scrollbar {
    display: none;
  }

  .acs-rv__card {
    flex: 0 0 clamp(140px, 20vw, 180px);
    display: grid;
    gap: var(--acs-space-xs);
    text-decoration: none;
    color: var(--acs-color-ink);
    scroll-snap-align: start;
  }

  .acs-rv__image {
    aspect-ratio: 4 / 5;
    border-radius: var(--acs-radius-sm);
    overflow: hidden;
    background: var(--acs-color-cream);
  }

  .acs-rv__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .acs-rv__title {
    font-size: var(--acs-type-small);
    font-weight: 600;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .acs-rv__price {
    color: var(--acs-color-accent);
    font-size: var(--acs-type-small);
    font-weight: 700;
  }
</style>

<script src="{{ 'acs-recently-viewed.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Recently Viewed",
  "tag": "section",
  "class": "acs-rv-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed"
    }
  ]
}
{% endschema %}
