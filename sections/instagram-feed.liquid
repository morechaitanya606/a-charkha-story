{% comment %}
  Acharkhastory Instagram grid.
  Uses Shopify-hosted manual images. For live Instagram sync, enable the
  Instafeed app embed instead of loading a third-party CDN script in theme code.
{% endcomment %}

{% liquid
  assign heading = section.settings.title | strip
  assign handle = section.settings.handle | strip | remove: '@'
  assign cta_label = section.settings.cta_label | strip
  assign has_images = false

  for block in section.blocks
    if block.settings.image != blank
      assign has_images = true
      break
    endif
  endfor
%}

{%- if has_images or section.blocks.size > 0 or request.design_mode -%}
  <section class="acs-section acs-instagram" id="InstagramFeed-{{ section.id }}">
    <div class="acs-container">
      {%- if heading != blank or handle != blank -%}
        <header class="acs-section-header acs-section-header--center">
          {%- if heading != blank -%}
            <h2 class="acs-h2">{{ heading | escape }}</h2>
          {%- endif -%}

          {%- if handle != blank -%}
            <a
              class="acs-button acs-button--link"
              href="https://www.instagram.com/{{ handle | escape }}"
              target="_blank"
              rel="noopener noreferrer"
            >
              @{{ handle | escape }}
            </a>
          {%- endif -%}
        </header>
      {%- endif -%}

      <div class="acs-instagram__grid">
        {%- for block in section.blocks -%}
          {% liquid
            assign image = block.settings.image
            assign image_alt = block.settings.image_alt | strip
            assign link = block.settings.link

            if link == blank and handle != blank
              assign link = 'https://www.instagram.com/' | append: handle
            endif

            if image_alt == blank
              assign image_alt = section.settings.fallback_alt
            endif
          %}

          {%- if image != blank or section.blocks.size > 0 or request.design_mode -%}
            <a
              class="acs-instagram__item"
              href="{{ link | default: routes.root_url }}"
              target="_blank"
              rel="noopener noreferrer"
              {{ block.shopify_attributes }}
            >
              {%- if image != blank -%}
                <img
                  src="{{ image | image_url: width: 420 }}"
                  srcset="{{ image | image_url: width: 240 }} 240w, {{ image | image_url: width: 420 }} 420w, {{ image | image_url: width: 640 }} 640w"
                  sizes="(max-width: 768px) 33vw, 16vw"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  alt="{{ image_alt | escape }}"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag }}
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if cta_label != blank and handle != blank -%}
        <div class="acs-instagram__cta acs-section-header acs-section-header--center">
          <a
            class="acs-button acs-button--ghost"
            href="https://www.instagram.com/{{ handle | escape }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            {{ cta_label | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "ACS Instagram Grid",
  "tag": "section",
  "class": "shopify-section--acs-instagram",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Follow the Story"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram handle",
      "default": "acharkhastory"
    },
    {
      "type": "text",
      "id": "fallback_alt",
      "label": "Fallback image alt text",
      "default": "Acharkhastory community style moment"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Follow on Instagram"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Instagram image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Post link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "ACS Instagram Grid",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
