{% comment %}
  Acharkhastory frequently bought together
  PDP bundle section with optional main product and complementary products in one add-to-bag flow.
{% endcomment %}

{% liquid
  assign heading = section.settings.heading | strip
  assign subheading = section.settings.subheading | strip
  assign bundle_products = product.metafields.custom.frequently_bought_together.value
  assign has_products = false
  assign initial_total = 0
  assign initial_count = 0
  assign max_products = section.settings.max_products

  if bundle_products == blank
    assign bundle_products = section.settings.products
  endif

  if section.settings.include_main_product and product != blank
    assign main_variant = product.selected_or_first_available_variant
    assign has_products = true
    if section.settings.preselect_products and main_variant.available
      assign initial_total = initial_total | plus: main_variant.price
      assign initial_count = initial_count | plus: 1
    endif
  endif

  for bundle_product in bundle_products limit: max_products
    if bundle_product != blank and bundle_product.id != product.id
      assign has_products = true
      assign bundle_variant = bundle_product.selected_or_first_available_variant
      if section.settings.preselect_products and bundle_variant.available
        assign initial_total = initial_total | plus: bundle_variant.price
        assign initial_count = initial_count | plus: 1
      endif
    endif
  endfor
%}

{%- if has_products or request.design_mode -%}
  <style>
    .acs-fbt {
      background: var(--acs-color-background);
      color: var(--acs-color-ink);
      padding-block: var(--acs-space-3xl);
    }

    .acs-fbt__inner {
      display: grid;
      gap: var(--acs-space-xl);
    }

    .acs-fbt__header {
      display: grid;
      gap: var(--acs-space-xs);
      max-width: 44rem;
    }

    .acs-fbt__eyebrow {
      color: var(--acs-color-accent);
      font-size: var(--acs-type-micro);
      font-weight: 700;
      letter-spacing: 0.08em;
      line-height: 1.2;
      margin: 0;
      text-transform: uppercase;
    }

    .acs-fbt__heading {
      color: var(--acs-color-primary);
      font-family: var(--acs-font-display);
      font-size: clamp(2rem, 4vw, 2.75rem);
      font-weight: 500;
      line-height: var(--acs-line-heading);
      margin: 0;
    }

    .acs-fbt__subheading {
      color: var(--acs-color-muted);
      line-height: var(--acs-line-body);
      margin: 0;
    }

    .acs-fbt__box {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.34fr);
      gap: var(--acs-space-xl);
      align-items: start;
      border: var(--acs-border-subtle);
      border-radius: var(--acs-radius-md);
      background: rgb(var(--acs-color-white-rgb) / 0.54);
      padding: var(--acs-space-lg);
    }

    .acs-fbt__items {
      display: grid;
      gap: var(--acs-space-md);
    }

    .acs-fbt__item {
      display: grid;
      grid-template-columns: auto 5.5rem minmax(0, 1fr);
      gap: var(--acs-space-md);
      align-items: center;
      position: relative;
      min-height: 6rem;
      border-bottom: var(--acs-border-subtle);
      padding-bottom: var(--acs-space-md);
    }

    .acs-fbt__item:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .acs-fbt__check {
      display: inline-grid;
      place-items: center;
      width: 2.35rem;
      height: 2.35rem;
      border-radius: var(--acs-radius-full);
      background: var(--acs-color-background);
      cursor: pointer;
      box-shadow: var(--acs-shadow-soft);
    }

    .acs-fbt__checkbox {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
    }

    .acs-fbt__check-ui {
      display: grid;
      place-items: center;
      width: 1.25rem;
      height: 1.25rem;
      border: 1px solid var(--acs-color-primary);
      border-radius: var(--acs-radius-full);
      color: var(--acs-color-background);
      font-size: var(--acs-type-caption);
      line-height: 1;
    }

    .acs-fbt__checkbox:checked + .acs-fbt__check-ui {
      background: var(--acs-color-primary);
    }

    .acs-fbt__checkbox:checked + .acs-fbt__check-ui::before {
      content: "\\2713";
    }

    .acs-fbt__checkbox:disabled + .acs-fbt__check-ui {
      opacity: 0.42;
    }

    .acs-fbt__media {
      aspect-ratio: 4 / 5;
      border-radius: var(--acs-radius-sm);
      background: var(--acs-color-cream);
      overflow: hidden;
    }

    .acs-fbt__media img,
    .acs-fbt__placeholder {
      width: 100%;
      height: 100%;
    }

    .acs-fbt__media img {
      object-fit: cover;
    }

    .acs-fbt__placeholder {
      display: grid;
      place-items: center;
      color: var(--acs-color-accent);
    }

    .acs-fbt__content {
      display: grid;
      gap: var(--acs-space-xs);
      min-width: 0;
    }

    .acs-fbt__badge {
      width: fit-content;
      border-radius: var(--acs-radius-full);
      background: rgb(var(--acs-color-primary-rgb) / 0.08);
      color: var(--acs-color-accent);
      font-size: var(--acs-type-micro);
      font-weight: 700;
      letter-spacing: 0.08em;
      line-height: 1;
      padding: 0.45rem 0.6rem;
      text-transform: uppercase;
    }

    .acs-fbt__title {
      color: var(--acs-color-primary);
      font-family: var(--acs-font-display);
      font-size: 1.2rem;
      font-weight: 500;
      line-height: 1.2;
      margin: 0;
    }

    .acs-fbt__title a {
      text-decoration: none;
    }

    .acs-fbt__title a:hover {
      text-decoration: underline;
    }

    .acs-fbt__price-row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--acs-space-xs);
      align-items: baseline;
      color: var(--acs-color-primary);
      font-weight: 700;
    }

    .acs-fbt__compare {
      color: var(--acs-color-muted);
      font-size: var(--acs-type-caption);
      text-decoration: line-through;
    }

    .acs-fbt__variant-select {
      width: min(100%, 22rem);
      min-height: 2.6rem;
      border: 1px solid var(--acs-color-border);
      border-radius: var(--acs-radius-sm);
      background: var(--acs-color-background);
      color: var(--acs-color-primary);
      padding-inline: var(--acs-space-sm);
    }

    .acs-fbt__summary {
      display: grid;
      gap: var(--acs-space-md);
      position: sticky;
      top: calc(var(--acs-header-height) + var(--acs-space-lg));
      border-radius: var(--acs-radius-md);
      background: var(--acs-color-primary);
      color: var(--acs-color-background);
      padding: var(--acs-space-lg);
    }

    .acs-fbt__summary-title {
      font-family: var(--acs-font-display);
      font-size: 1.5rem;
      font-weight: 500;
      line-height: 1.2;
      margin: 0;
    }

    .acs-fbt__summary-line {
      display: flex;
      gap: var(--acs-space-md);
      justify-content: space-between;
      color: rgb(var(--acs-color-background-rgb) / 0.78);
      font-size: var(--acs-type-small);
      line-height: 1.4;
    }

    .acs-fbt__total {
      color: var(--acs-color-background);
      font-size: 1.45rem;
      font-weight: 700;
    }

    .acs-fbt__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3.15rem;
      border: 1px solid var(--acs-color-background);
      border-radius: var(--acs-radius-sm);
      background: var(--acs-color-background);
      color: var(--acs-color-primary);
      cursor: pointer;
      font-size: var(--acs-type-small);
      font-weight: 700;
      letter-spacing: 0.08em;
      line-height: 1;
      padding: 0.9rem 1rem;
      text-transform: uppercase;
      transition: background var(--acs-duration-base) var(--acs-ease), opacity var(--acs-duration-base) var(--acs-ease);
    }

    .acs-fbt__button:hover {
      background: var(--acs-color-surface);
    }

    .acs-fbt__button:disabled {
      cursor: not-allowed;
      opacity: 0.55;
    }

    .acs-fbt__message {
      min-height: 1.25rem;
      color: var(--acs-color-background);
      font-size: var(--acs-type-caption);
      line-height: 1.4;
      margin: 0;
    }

    .acs-fbt__empty {
      border: var(--acs-border-subtle);
      border-radius: var(--acs-radius-md);
      background: rgb(var(--acs-color-white-rgb) / 0.52);
      color: var(--acs-color-muted);
      padding: var(--acs-space-xl);
    }

    @media (max-width: 768px) {
      .acs-fbt {
        padding-block: var(--acs-space-2xl);
      }

      .acs-fbt__inner {
        width: min(100% - calc(var(--acs-edge) * 2), var(--acs-page-width));
      }

      .acs-fbt__box {
        grid-template-columns: 1fr;
        padding: var(--acs-space-md);
      }

      .acs-fbt__item {
        grid-template-columns: auto 4.75rem minmax(0, 1fr);
        gap: var(--acs-space-sm);
      }

      .acs-fbt__summary {
        position: static;
      }
    }
  </style>

  <section
    class="acs-fbt"
    id="FrequentlyBoughtTogether-{{ section.id }}"
    data-acs-fbt
    data-cart-add-url="{{ routes.cart_add_url }}.js"
    data-cart-url="{{ routes.cart_url }}"
    data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
    data-add-label="{{ section.settings.add_label | escape }}"
    data-adding-label="{{ section.settings.adding_label | escape }}"
    data-added-label="{{ section.settings.added_label | escape }}"
    data-empty-selection-message="{{ section.settings.empty_selection_message | escape }}"
    data-error-message="{{ section.settings.error_message | escape }}"
    data-redirect-after-add="{{ section.settings.redirect_after_add }}"
  >
    <div class="acs-fbt__inner acs-page-width">
      <header class="acs-fbt__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="acs-fbt__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="acs-fbt__heading">{{ heading | escape }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="acs-fbt__subheading">{{ subheading | escape }}</p>
        {%- endif -%}
      </header>

      {%- if has_products -%}
        <div class="acs-fbt__box">
          <div class="acs-fbt__items">
            {%- if section.settings.include_main_product and product != blank -%}
              {%- liquid
                assign main_variant = product.selected_or_first_available_variant
                assign main_checked = false
                if section.settings.preselect_products and main_variant.available
                  assign main_checked = true
                endif
              -%}
              {%- render 'fbt-product-row',
                row_product: product,
                row_variant: main_variant,
                row_checked: main_checked,
                row_badge: section.settings.main_product_badge,
                select_label: section.settings.select_product_label,
                variant_label: section.settings.variant_label,
                sold_out_label: section.settings.sold_out_label
              -%}
            {%- endif -%}

            {%- for bundle_product in bundle_products limit: max_products -%}
              {%- if bundle_product != blank and bundle_product.id != product.id -%}
                {%- liquid
                  assign bundle_variant = bundle_product.selected_or_first_available_variant
                  assign bundle_checked = false
                  if section.settings.preselect_products and bundle_variant.available
                    assign bundle_checked = true
                  endif
                -%}
                {%- render 'fbt-product-row',
                  row_product: bundle_product,
                  row_variant: bundle_variant,
                  row_checked: bundle_checked,
                  row_badge: section.settings.companion_product_badge,
                  select_label: section.settings.select_product_label,
                  variant_label: section.settings.variant_label,
                  sold_out_label: section.settings.sold_out_label
                -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          <aside class="acs-fbt__summary" aria-label="{{ section.settings.summary_label | escape }}">
            <h3 class="acs-fbt__summary-title">{{ section.settings.summary_title | escape }}</h3>
            <div class="acs-fbt__summary-line">
              <span>
                <span data-acs-fbt-count>{{ initial_count }}</span>
                {{ section.settings.selected_label | escape }}
              </span>
              <strong class="acs-fbt__total" data-acs-fbt-total>{{ initial_total | money }}</strong>
            </div>
            <button
              type="button"
              class="acs-fbt__button"
              data-acs-fbt-submit
              {% if initial_count == 0 %}disabled{% endif %}
            >
              {{ section.settings.add_label | escape }}
            </button>
            <p class="acs-fbt__message" data-acs-fbt-message aria-live="polite"></p>
          </aside>
        </div>
      {%- else -%}
        <div class="acs-fbt__empty">
          <h2 class="acs-fbt__heading">{{ section.settings.empty_heading | escape }}</h2>
          <p class="acs-fbt__subheading">{{ section.settings.empty_text | escape }}</p>
        </div>
      {%- endif -%}
    </div>
  </section>

  <script src="{{ 'frequently-bought-together.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Bundle Upsell",
  "tag": "section",
  "class": "shopify-section--frequently-bought-together",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Bundle and save time"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Bought Together"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Add the full set in one step: the piece you are viewing plus customer-favourite companions."
    },
    {
      "type": "checkbox",
      "id": "include_main_product",
      "label": "Include the current product",
      "default": true
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Fallback bundle products",
      "limit": 6
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum companion products",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "preselect_products",
      "label": "Preselect available products",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "redirect_after_add",
      "label": "Redirect to cart after add",
      "default": false
    },
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "main_product_badge",
      "label": "Main product badge",
      "default": "This item"
    },
    {
      "type": "text",
      "id": "companion_product_badge",
      "label": "Companion product badge",
      "default": "Often paired"
    },
    {
      "type": "text",
      "id": "summary_label",
      "label": "Summary aria label",
      "default": "Frequently bought together bundle summary"
    },
    {
      "type": "text",
      "id": "summary_title",
      "label": "Summary title",
      "default": "Bundle total"
    },
    {
      "type": "text",
      "id": "selected_label",
      "label": "Selected count label",
      "default": "selected"
    },
    {
      "type": "text",
      "id": "add_label",
      "label": "Add button label",
      "default": "Add all to bag"
    },
    {
      "type": "text",
      "id": "adding_label",
      "label": "Adding state label",
      "default": "Adding..."
    },
    {
      "type": "text",
      "id": "added_label",
      "label": "Added state label",
      "default": "Added to bag"
    },
    {
      "type": "text",
      "id": "variant_label",
      "label": "Variant selector label",
      "default": "Choose option for"
    },
    {
      "type": "text",
      "id": "select_product_label",
      "label": "Checkbox label",
      "default": "Select"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Sold out label",
      "default": "Sold Out"
    },
    {
      "type": "text",
      "id": "empty_selection_message",
      "label": "Empty selection message",
      "default": "Choose at least one product to add."
    },
    {
      "type": "text",
      "id": "error_message",
      "label": "Error message",
      "default": "Something went wrong. Please try again."
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Editor empty heading",
      "default": "Choose bundle products"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Editor empty text",
      "default": "Add fallback products here or set product metafield custom.frequently_bought_together."
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Bundle Upsell"
    }
  ]
}
{% endschema %}
