{% comment %}
  ACHARKHASTORY — Explore Stories (Editorial Section)
  2 large landscape cards side-by-side with gradient text overlays.
{% endcomment %}

{{ 'acharkhastory.css' | asset_url | stylesheet_tag }}

<style>
  .explore-stories {
    max-width: var(--acs-container);
    margin-inline: auto;
    padding-inline: var(--acs-edge);
    padding-block: var(--acs-section-py);
  }

  .explore-stories__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--acs-gutter);
  }

  .explore-stories__card {
    position: relative;
    aspect-ratio: 3 / 2;
    border-radius: var(--acs-r-md);
    overflow: hidden;
    text-decoration: none;
    display: block;
    background: var(--acs-surface);
  }

  .explore-stories__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--acs-ease);
  }

  .explore-stories__card:hover img {
    transform: scale(1.03);
  }

  .explore-stories__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26, 16, 8, 0.8) 0%, rgba(26, 16, 8, 0) 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--acs-sp-xl);
    color: var(--acs-ivory);
  }

  .explore-stories__label {
    font-family: var(--acs-font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(253, 246, 238, 0.7);
    margin-bottom: var(--acs-sp-xs);
  }

  .explore-stories__title {
    font-family: var(--acs-font-display);
    font-size: 28px;
    font-weight: 500;
    color: var(--acs-ivory);
    margin: 0 0 var(--acs-sp-xs);
    line-height: 1.2;
  }

  .explore-stories__desc {
    font-family: var(--acs-font-body);
    font-size: 13px;
    color: rgba(253, 246, 238, 0.8);
    margin: 0 0 var(--acs-sp-md);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .explore-stories__cta {
    font-family: var(--acs-font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--acs-ivory);
    text-decoration: underline;
    text-underline-offset: 4px;
    display: inline-block;
  }

  @media (max-width: 768px) {
    .explore-stories__grid {
      grid-template-columns: 1fr;
    }
    .explore-stories__card {
      aspect-ratio: auto;
      height: 300px;
    }
    .explore-stories__overlay {
      padding: var(--acs-sp-lg);
    }
  }
</style>

<section class="explore-stories" id="explore-stories">
  <div class="explore-stories__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="explore-stories__card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.title | escape }}"
            loading="lazy"
            width="800"
            height="533"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag }}
        {%- endif -%}
        
        <div class="explore-stories__overlay">
          {%- if block.settings.label != blank -%}
            <span class="explore-stories__label">{{ block.settings.label }}</span>
          {%- endif -%}
          
          <h3 class="explore-stories__title">{{ block.settings.title }}</h3>
          
          {%- if block.settings.description != blank -%}
            <p class="explore-stories__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          
          {%- if block.settings.cta_label != blank -%}
            <span class="explore-stories__cta">{{ block.settings.cta_label }} →</span>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Stories",
  "tag": "section",
  "class": "explore-stories-section",
  "settings": [],
  "blocks": [
    {
      "type": "story",
      "name": "Story Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image (Landscape 3:2)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Eyebrow label",
          "default": "Craft Spotlight"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Headline",
          "default": "The women of Kutch who keep Ajrakh alive"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description",
          "default": "Meet the artisans preserving a 3000-year-old tradition."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Link label",
          "default": "Explore Ajrakh"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Stories",
      "blocks": [
        { "type": "story" },
        { "type": "story", "settings": { "label": "New Season", "title": "Block prints, natural dyes, and summer ease", "description": "Airy cottons for the warmer months ahead.", "cta_label": "Shop New Arrivals" } }
      ]
    }
  ],
  "max_blocks": 2
}
{% endschema %}
