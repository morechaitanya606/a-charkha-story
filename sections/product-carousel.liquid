{% comment %}
  Acharkhastory product carousel.
  Used for New Arrivals, Bestsellers, and other product discovery rows.
{% endcomment %}

{% liquid
  assign heading = section.settings.title | strip
  assign subtitle = section.settings.subtitle | strip
  assign collection = section.settings.collection
  assign has_products = false
  assign view_all_link = section.settings.view_all_link

  if collection != blank and collection.products.size > 0
    assign has_products = true
  endif

  if view_all_link == blank and collection != blank
    assign view_all_link = collection.url
  endif
%}

{%- if has_products or request.design_mode -%}
  <section
    class="acs-section acs-product-carousel acs-product-carousel--mobile-{{ section.settings.mobile_layout }}"
    id="ProductCarousel-{{ section.id }}"
    data-acs-product-carousel
  >
    <div class="acs-container acs-product-carousel__inner">
      <header class="acs-product-carousel__header">
        <div class="acs-section-header">
          {%- if heading != blank -%}
            <h2 class="acs-h2">{{ heading | escape }}</h2>
          {%- endif -%}

          {%- if subtitle != blank -%}
            <p class="acs-section-header__subtitle">{{ subtitle | escape }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.view_all_text != blank and view_all_link != blank -%}
          <a class="acs-button acs-button--link" href="{{ view_all_link }}">
            {{ section.settings.view_all_text | escape }}
          </a>
        {%- endif -%}
      </header>

      <div
        class="acs-product-carousel__track"
        data-acs-product-carousel-track
        aria-label="{{ heading | escape }}"
      >
        {%- if has_products -%}
          {%- for product in collection.products limit: section.settings.max_products -%}
            <div class="acs-product-carousel__item">
              {%- render 'product-card-acs',
                product: product,
                show_badge: true,
                show_craft_tag: true,
                card_index: forloop.index
              -%}
            </div>
          {%- endfor -%}
        {%- elsif request.design_mode -%}
          {%- for index in (1..4) -%}
            <div class="acs-product-carousel__item">
              <article class="product-card-acs">
                <div class="product-card-acs__media">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>

                <div class="product-card-acs__info">
                  {%- if section.settings.placeholder_craft != blank -%}
                    <span class="product-card-acs__craft-tag">
                      {{ section.settings.placeholder_craft | escape }}
                    </span>
                  {%- endif -%}

                  <h3 class="product-card-acs__title">
                    {{ section.settings.placeholder_title | escape }} {{ index }}
                  </h3>

                  {%- if section.settings.placeholder_price != blank -%}
                    <div class="product-card-acs__price-row">
                      <span class="product-card-acs__price">
                        {{ section.settings.placeholder_price | escape }}
                      </span>
                    </div>
                  {%- endif -%}
                </div>
              </article>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if has_products and collection.products.size > 1 -%}
        <button
          class="acs-product-carousel__arrow acs-product-carousel__arrow--prev"
          type="button"
          aria-label="{{ section.settings.previous_label | escape }}"
          data-acs-carousel-prev
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>

        <button
          class="acs-product-carousel__arrow acs-product-carousel__arrow--next"
          type="button"
          aria-label="{{ section.settings.next_label | escape }}"
          data-acs-carousel-next
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M9 6l6 6-6 6"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </section>

  <script src="{{ 'product-carousel-acs.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "ACS Product Carousel",
  "tag": "section",
  "class": "shopify-section--acs-product-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Fresh craft-led pieces, released in small batches."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "grid",
          "label": "Two-column grid"
        },
        {
          "value": "scroll",
          "label": "Horizontal scroll"
        }
      ],
      "default": "grid"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "text",
      "id": "previous_label",
      "label": "Previous button label",
      "default": "Previous products"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "Next button label",
      "default": "Next products"
    },
    {
      "type": "text",
      "id": "placeholder_craft",
      "label": "Editor placeholder craft",
      "default": "Ajrakh"
    },
    {
      "type": "text",
      "id": "placeholder_title",
      "label": "Editor placeholder title",
      "default": "Sample Product"
    },
    {
      "type": "text",
      "id": "placeholder_price",
      "label": "Editor placeholder price",
      "default": "Rs. 2400"
    }
  ],
  "presets": [
    {
      "name": "ACS Product Carousel"
    }
  ]
}
{% endschema %}
