{% comment %}
  ACHARKHASTORY — Product Carousel
  Horizontal scrolling product row from a Shopify collection.
  Uses snippets/product-card-acs.liquid for each card.
{% endcomment %}

{{ 'acharkhastory.css' | asset_url | stylesheet_tag }}

<style>
  .product-carousel {
    padding-block: var(--acs-section-py);
    overflow: hidden;
  }

  .product-carousel__inner {
    max-width: var(--acs-container);
    margin-inline: auto;
    padding-inline: var(--acs-edge);
  }

  .product-carousel__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--acs-sp-lg);
  }

  .product-carousel__title {
    font-family: var(--acs-font-display);
    font-size: var(--acs-fs-h2);
    font-weight: 500;
    color: var(--acs-primary);
    margin: 0;
  }

  .product-carousel__view-all {
    font-family: var(--acs-font-body);
    font-size: var(--acs-fs-nav);
    color: var(--acs-secondary);
    text-decoration: none;
    white-space: nowrap;
  }

  .product-carousel__view-all:hover {
    text-decoration: underline;
  }

  .product-carousel__track-wrap {
    position: relative;
  }

  .product-carousel__track {
    display: flex;
    gap: var(--acs-sp-md);
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--acs-sp-xs);
  }

  .product-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .product-carousel__card {
    flex: 0 0 280px;
    min-width: 0;
  }

  /* Arrow nav */
  .product-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-100%);
    z-index: 2;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--acs-border);
    background: var(--acs-white);
    color: var(--acs-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(61, 34, 16, 0.1);
    transition: all var(--acs-duration) var(--acs-ease);
  }

  .product-carousel__arrow:hover {
    background: var(--acs-cream);
    border-color: var(--acs-secondary);
  }

  .product-carousel__arrow--prev { left: -20px; }
  .product-carousel__arrow--next { right: -20px; }

  .product-carousel__arrow svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 768px) {
    .product-carousel__card {
      flex: 0 0 60vw;
    }

    .product-carousel__arrow {
      display: none;
    }

    .product-carousel__header {
      flex-direction: column;
      gap: var(--acs-sp-xs);
    }
  }

  @media (max-width: 480px) {
    .product-carousel__card {
      flex: 0 0 70vw;
    }
  }
</style>

{%- assign collection = collections[section.settings.collection] -%}

<section class="product-carousel" id="product-carousel-{{ section.id }}">
  <div class="product-carousel__inner">
    <div class="product-carousel__header">
      <h2 class="product-carousel__title">{{ section.settings.title }}</h2>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="product-carousel__view-all">
          {{ section.settings.view_all_text | default: 'View all →' }}
        </a>
      {%- elsif collection -%}
        <a href="{{ collection.url }}" class="product-carousel__view-all">
          {{ section.settings.view_all_text | default: 'View all →' }}
        </a>
      {%- endif -%}
    </div>

    <div class="product-carousel__track-wrap">
      <div class="product-carousel__track" id="carousel-track-{{ section.id }}">
        {%- if collection -%}
          {%- for product in collection.products limit: section.settings.max_products -%}
            <div class="product-carousel__card">
              {%- render 'product-card-acs', product: product, show_badge: true, show_craft_tag: true, card_index: forloop.index -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="product-carousel__card">
              <div class="product-card-acs">
                <div class="product-card-acs__media" style="background:var(--acs-cream);">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
                <div class="product-card-acs__info">
                  <span class="product-card-acs__craft-tag">Ajrakh</span>
                  <h3 class="product-card-acs__title">Sample Product {{ i }}</h3>
                  <div class="product-card-acs__price-row">
                    <span class="product-card-acs__price">₹2,400</span>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button
        class="product-carousel__arrow product-carousel__arrow--prev"
        aria-label="Scroll left"
        onclick="document.getElementById('carousel-track-{{ section.id }}').scrollBy({left: -300, behavior: 'smooth'})"
      >
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button
        class="product-carousel__arrow product-carousel__arrow--next"
        aria-label="Scroll right"
        onclick="document.getElementById('carousel-track-{{ section.id }}').scrollBy({left: 300, behavior: 'smooth'})"
      >
        <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18"/></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Carousel",
  "tag": "section",
  "class": "product-carousel-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "View all →"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link (optional, defaults to collection)"
    }
  ],
  "presets": [
    {
      "name": "Product Carousel"
    }
  ]
}
{% endschema %}
