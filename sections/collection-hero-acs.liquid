{% comment %}
  Acharkhastory — Collection Hero Banner
  Full-width hero with collection image, title, description, product count.
{% endcomment %}

{%- liquid
  assign bg_image = section.settings.background_image | default: collection.image
  assign show_count = section.settings.show_product_count
-%}

<section class="acs-collection-hero" id="CollectionHero-{{ section.id }}">
  {%- if bg_image != blank -%}
    <div class="acs-collection-hero__media">
      {{
        bg_image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '640, 960, 1280, 1600, 1920',
          sizes: '100vw',
          alt: collection.title,
          class: 'acs-collection-hero__image',
          width: bg_image.width,
          height: bg_image.height
      }}
    </div>
  {%- endif -%}

  <div class="acs-collection-hero__overlay"></div>

  <div class="acs-collection-hero__content acs-page-width acs-reveal">
    {%- if section.settings.eyebrow != blank -%}
      <span class="acs-collection-hero__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}

    <h1 class="acs-collection-hero__title">{{ collection.title | escape }}</h1>

    {%- if collection.description != blank -%}
      <div class="acs-collection-hero__description">
        {{ collection.description | strip_html | truncate: 200 }}
      </div>
    {%- endif -%}

    {%- if show_count -%}
      <span class="acs-collection-hero__count">
        {{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
      </span>
    {%- endif -%}
  </div>
</section>

<style>
  .acs-collection-hero {
    position: relative;
    min-height: clamp(240px, 35vw, 420px);
    display: grid;
    align-items: end;
    background: var(--acs-color-primary);
    color: var(--acs-color-background);
    overflow: hidden;
  }

  .acs-collection-hero__media {
    position: absolute;
    inset: 0;
  }

  .acs-collection-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .acs-collection-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgb(var(--acs-color-primary-rgb) / 0.75) 0%,
      rgb(var(--acs-color-primary-rgb) / 0.25) 50%,
      rgb(var(--acs-color-primary-rgb) / 0.1) 100%
    );
  }

  .acs-collection-hero__content {
    position: relative;
    display: grid;
    gap: var(--acs-space-sm);
    padding-block: var(--acs-space-2xl);
    max-width: 42rem;
  }

  .acs-collection-hero__eyebrow {
    color: var(--acs-color-surface);
    font-size: var(--acs-type-micro);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .acs-collection-hero__title {
    margin: 0;
    font-family: var(--acs-font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 500;
    line-height: var(--acs-line-tight);
    color: var(--acs-color-background);
  }

  .acs-collection-hero__description {
    color: rgb(var(--acs-color-background-rgb) / 0.8);
    font-size: var(--acs-type-body);
    line-height: var(--acs-line-body);
    max-width: 36rem;
  }

  .acs-collection-hero__count {
    color: rgb(var(--acs-color-background-rgb) / 0.6);
    font-size: var(--acs-type-small);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .acs-collection-hero {
      min-height: 200px;
    }

    .acs-collection-hero__content {
      padding-block: var(--acs-space-xl);
    }
  }
</style>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "section",
  "class": "acs-collection-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Explore"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Custom background image",
      "info": "Falls back to collection image if not set"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection Hero"
    }
  ]
}
{% endschema %}
