{% comment %}
  Acharkhastory email signup.
  Supports Shopify customer form by default and Klaviyo embed by form ID.
{% endcomment %}

{% liquid
  assign heading = section.settings.title | strip
  assign subtitle = section.settings.subtitle | strip
  assign klaviyo_form_id = section.settings.klaviyo_form_id | strip
%}

<section class="acs-section acs-email-signup" id="EmailSignup-{{ section.id }}">
  <div class="acs-container">
    <div class="acs-email-signup__inner">
      <div>
        {%- if heading != blank -%}
          <h2 class="acs-email-signup__title">{{ heading | escape }}</h2>
        {%- endif -%}

        {%- if subtitle != blank -%}
          <p class="acs-email-signup__text">{{ subtitle | escape }}</p>
        {%- endif -%}
      </div>

      <div>
        {%- if klaviyo_form_id != blank -%}
          <div class="klaviyo-form-{{ klaviyo_form_id | escape }}"></div>
        {%- else -%}
          {%- form 'customer', id: 'email-signup-form' -%}
            <input type="hidden" name="contact[tags]" value="{{ section.settings.customer_tags | escape }}">
            <div class="acs-email-signup__form">
              <input
                class="acs-input"
                type="email"
                name="contact[email]"
                placeholder="{{ section.settings.placeholder | escape }}"
                autocomplete="email"
                required
                aria-label="{{ section.settings.email_label | escape }}"
              >
              <button class="acs-button acs-button--light" type="submit">
                {{ section.settings.button_label | escape }}
              </button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="acs-email-signup__success">{{ section.settings.success_message | escape }}</p>
            {%- endif -%}
          {%- endform -%}
        {%- endif -%}

        {%- if section.settings.fine_print != blank -%}
          <p class="acs-email-signup__fine-print">{{ section.settings.fine_print | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ACS Email Signup",
  "tag": "section",
  "class": "shopify-section--acs-email-signup",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Join the Acharkhastory Family"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Be the first to know about new collections, craft stories, and exclusive offers."
    },
    {
      "type": "text",
      "id": "klaviyo_form_id",
      "label": "Klaviyo form ID",
      "info": "Leave blank to use Shopify customer signup."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email input accessible label",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you. Welcome to the story."
    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "Fine print",
      "default": "No spam. Unsubscribe anytime."
    },
    {
      "type": "text",
      "id": "customer_tags",
      "label": "Customer tags",
      "default": "newsletter"
    }
  ],
  "presets": [
    {
      "name": "ACS Email Signup"
    }
  ]
}
{% endschema %}
